<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for(:title) || "Samarka Association - Admin" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= javascript_importmap_tags %>
    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">

    <!-- Bootstrap 5 & Fonts -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.css">

    <!-- Chart.js + Chartkick -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartkick@5.0.1/dist/chartkick.min.js"></script>

    <!-- jQuery + Select2 -->
    <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <link href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css" rel="stylesheet" />

    <%= stylesheet_link_tag "sidebar_fallback", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "layout_fix", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "auth", "data-turbo-track": "reload" if !user_signed_in? %>

    <!-- ADMIN HEADER ALIGNMENT FIX -->
    <style>
      /* ADMIN HEADER PERFECT ALIGNMENT */
      .header .container-fluid {
        display: flex !important;
        align-items: center !important;
        justify-content: space-between !important;
        height: 100% !important;
        padding: 0 1.5rem !important;
        width: 100% !important;
        max-width: none !important;
        margin: 0 !important;
        box-sizing: border-box !important;
      }

      /* LEFT SIDE - MOBILE TOGGLE + BRAND */
      .header .d-flex.align-items-center:first-of-type {
        display: flex !important;
        align-items: center !important;
        justify-content: flex-start !important;
        flex: 0 0 auto !important;
        gap: 1rem !important;
      }

      /* RIGHT SIDE - PROFILE BUTTON */
      .header .d-flex.align-items-center.gap-3.ms-auto {
        display: flex !important;
        align-items: center !important;
        justify-content: flex-end !important;
        flex: 0 0 auto !important;
        gap: 1rem !important;
        margin-left: auto !important;
        padding-right: 0 !important;
      }

      /* ENHANCED PROFILE BUTTON STYLING */
      .header .btn-outline-secondary {
        border-color: rgba(255, 255, 255, 0.3) !important;
        color: #ffffff !important;
        background: rgba(255, 255, 255, 0.1) !important;
        border-radius: 8px !important;
        padding: 0.5rem 1rem !important;
        font-weight: 500 !important;
        transition: all 0.3s ease !important;
      }

      .header .btn-outline-secondary:hover {
        background: rgba(255, 255, 255, 0.2) !important;
        border-color: rgba(255, 255, 255, 0.5) !important;
        color: #ffffff !important;
        transform: translateY(-1px) !important;
      }

      /* BRAND STYLING */
      .header .brand-icon {
        color: #ffffff !important;
        background: rgba(255, 255, 255, 0.1) !important;
        border: 1px solid rgba(255, 255, 255, 0.2) !important;
        width: 42px !important;
        height: 42px !important;
        border-radius: 12px !important;
        display: flex !important;
        align-items: center !important;
        justify-content: center !important;
        font-size: 1.5rem !important;
      }

      .header .brand-text {
        color: #ffffff !important;
        font-weight: 700 !important;
        font-size: 1.5rem !important;
        margin: 0 !important;
        white-space: nowrap !important;
      }

      /* MOBILE RESPONSIVE */
      @media (max-width: 768px) {
        .header .container-fluid {
          padding: 0 1rem !important;
        }

        .header .brand-text {
          font-size: 1.25rem !important;
        }

        .header .brand-icon {
          width: 36px !important;
          height: 36px !important;
          font-size: 1.25rem !important;
        }

        .header .btn-outline-secondary {
          padding: 0.375rem 0.75rem !important;
          font-size: 0.875rem !important;
        }
      }

      @media (max-width: 480px) {
        .header .container-fluid {
          padding: 0 0.75rem !important;
        }

        .header .d-flex.align-items-center.gap-3.ms-auto {
          gap: 0.5rem !important;
        }
      }
    </style>
  </head>

  <body class="insurance-app">
    <% if user_signed_in? %>
      <header class="header">
        <div class="container-fluid h-100">
          <div class="d-flex align-items-center justify-content-between h-100" style="padding-left:1.5rem; padding-right:1.5rem; width:100%;">
            <button class="mobile-toggle d-md-none" type="button" onclick="document.querySelector('.modern-sidebar').classList.toggle('show')">
              <i class="fas fa-bars"></i>
            </button>
            <div class="d-flex align-items-center">
              <div class="brand-icon"><i class="bi bi-diagram-3-fill"></i></div>
              <h1 class="brand-text ms-3 mb-0 d-none d-md-block">Samarka Association</h1>
            </div>
            <div class="d-flex align-items-center gap-3 ms-auto">
              <div class="dropdown">
                <button class="btn btn-outline-secondary btn-sm dropdown-toggle" type="button" data-bs-toggle="dropdown">
                  <i class="fas fa-user-circle me-2"></i>
                  <span class="d-none d-sm-inline"><%= current_user.display_name %></span>
                </button>
                <ul class="dropdown-menu dropdown-menu-end">
                  <li><span class="dropdown-item-text small text-muted"><%= current_user.role&.name || "No Role" %></span></li>
                  <li><hr class="dropdown-divider"></li>
                  <li><%= link_to destroy_user_session_path, class: "dropdown-item", data: { turbo_method: :delete } do %>
                    <i class="fas fa-sign-out-alt me-2"></i>Logout
                  <% end %></li>
                </ul>
              </div>
            </div>
          </div>
        </div>
      </header>

      <%= render "layouts/sidebar" %>

      <main class="main-content">
        <div class="container-fluid">
          <% if notice %>
            <div id="toast-notification" class="toast-notification toast-success" style="position:fixed; top:80px; right:20px; z-index:9999; width:350px; background:#d1edda; border:1px solid #c3e6cb; color:#155724; border-radius:0.375rem; box-shadow:0 0.5rem 1rem rgba(0,0,0,0.15); transform:translateX(100%); transition:transform 0.3s ease-in-out;">
              <div style="padding:1rem; display:flex; align-items:center; justify-content:space-between;">
                <div class="d-flex align-items-center"><i class="fas fa-check-circle me-2"></i><span><%= notice %></span></div>
                <button type="button" class="btn-close ms-3" onclick="closeToast()" style="background:none; border:none; color:#155724; cursor:pointer; font-size:1.2rem;">&times;</button>
              </div>
            </div>
          <% end %>
          <% if alert %>
            <div id="toast-notification" class="toast-notification toast-danger" style="position:fixed; top:80px; right:20px; z-index:9999; width:350px; background:#f8d7da; border:1px solid #f5c6cb; color:#721c24; border-radius:0.375rem; box-shadow:0 0.5rem 1rem rgba(0,0,0,0.15); transform:translateX(100%); transition:transform 0.3s ease-in-out;">
              <div style="padding:1rem; display:flex; align-items:center; justify-content:space-between;">
                <div class="d-flex align-items-center"><i class="fas fa-exclamation-triangle me-2"></i><span><%= alert %></span></div>
                <button type="button" class="btn-close ms-3" onclick="closeToast()" style="background:none; border:none; color:#721c24; cursor:pointer; font-size:1.2rem;">&times;</button>
              </div>
            </div>
          <% end %>

          <div class="content-area">
            <%= yield %>
          </div>
        </div>
      </main>
    <% else %>
      <div class="auth-wrapper">
        <div class="auth-pattern"></div>
        <div class="floating-shape shape-1"></div>
        <div class="floating-shape shape-2"></div>
        <div class="floating-shape shape-3"></div>
        <%= yield %>
      </div>
    <% end %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
      function saveSidebarScrollPosition() {
        const s = document.querySelector('.modern-sidebar, .sidebar');
        if (s) sessionStorage.setItem('sidebarScrollPosition', s.scrollTop.toString());
      }
      function restoreSidebarScrollPosition() {
        const s = document.querySelector('.modern-sidebar, .sidebar');
        const v = sessionStorage.getItem('sidebarScrollPosition');
        if (s && v) setTimeout(() => { s.scrollTop = parseInt(v, 10); }, 100);
      }
      function setupSidebarScrollTracking() {
        const s = document.querySelector('.modern-sidebar, .sidebar');
        if (!s) return;
        s.addEventListener('scroll', saveSidebarScrollPosition);
        s.querySelectorAll('a').forEach(l => l.addEventListener('click', saveSidebarScrollPosition));
      }
      function initToastNotifications() {
        const t = document.getElementById('toast-notification');
        if (t) {
          setTimeout(() => { t.style.transform = 'translateX(0)'; }, 100);
          setTimeout(() => { closeToast(); }, 5000);
        }
      }
      function closeToast() {
        const t = document.getElementById('toast-notification');
        if (t) { t.style.transform = 'translateX(100%)'; setTimeout(() => { if (t.parentNode) t.parentNode.removeChild(t); }, 300); }
      }
      document.addEventListener('DOMContentLoaded', function() { initToastNotifications(); setupSidebarScrollTracking(); restoreSidebarScrollPosition(); });
      document.addEventListener('turbo:load', function() { initToastNotifications(); restoreSidebarScrollPosition(); setupSidebarScrollTracking(); });
      document.addEventListener('turbo:before-visit', saveSidebarScrollPosition);
      window.addEventListener('beforeunload', saveSidebarScrollPosition);
      document.addEventListener('keydown', e => { if (e.key === 'Escape') closeToast(); });
    </script>
  </body>
</html>
