<!DOCTYPE html>
<html>
<head>
  <title>Login - InterConnect</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <!-- Bootstrap CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <!-- Font Awesome -->
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
  <!-- Bootstrap Icons -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.css">
  <!-- Poppins Font -->
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <!-- Simple Login CSS -->
  <%= stylesheet_link_tag "simple_login", "data-turbo-track": "reload" %>
</head>
<body>

<!-- Network background canvas -->
<canvas id="network-canvas" style="position:fixed;top:0;left:0;width:100%;height:100%;z-index:0;pointer-events:none;"></canvas>

<!-- Simple Centered Login Page -->
<div class="simple-login-wrapper">
  <div class="simple-login-container">
    <div class="simple-login-card">
      <!-- Flash Messages -->
      <% if notice && notice.present? && !notice.include?("http") %>
        <div class="alert alert-success mb-3">
          <i class="fas fa-check-circle me-2"></i><%= notice %>
        </div>
      <% end %>

      <% if alert && alert.present? && !alert.include?("http") %>
        <div class="alert alert-danger mb-3">
          <i class="fas fa-exclamation-triangle me-2"></i><%= alert %>
        </div>
      <% end %>

      <!-- Logo Section -->
      <div class="text-center mb-4">
        <div class="brand-lockup">
          <div class="simple-logo">
            <i class="bi bi-diagram-3-fill"></i>
          </div>
          <div class="brand-wordmark">
            <h2 class="simple-title mb-0">InterConnect</h2>
            <p class="simple-subtitle mb-0">Business Networking Forum ERP</p>
          </div>
        </div>
      </div>

      <!-- Login Form -->
      <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
        <div class="mb-3">
          <%= f.label :email, "Email", class: "form-label" %>
          <div class="input-group">
            <span class="input-group-text">
              <i class="fas fa-envelope"></i>
            </span>
            <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-control", placeholder: "you@example.com" %>
          </div>
        </div>

        <div class="mb-3">
          <%= f.label :password, "Password", class: "form-label" %>
          <div class="input-group">
            <span class="input-group-text">
              <i class="fas fa-lock"></i>
            </span>
            <%= f.password_field :password, autocomplete: "current-password", class: "form-control", placeholder: "••••••••" %>
          </div>
        </div>

        <div class="d-flex justify-content-between align-items-center mb-3">
          <% if devise_mapping.rememberable? %>
            <div class="form-check">
              <%= f.check_box :remember_me, class: "form-check-input" %>
              <%= f.label :remember_me, "Remember me", class: "form-check-label" %>
            </div>
          <% end %>
          <% if devise_mapping.recoverable? %>
            <%= link_to "Forgot password?", new_password_path(resource_name), class: "small text-decoration-none", style: "color: #667eea;" %>
          <% end %>
        </div>

        <%= f.submit "Sign In", class: "btn btn-primary w-100 py-3 fs-5 fw-semibold" %>
      <% end %>

    </div>
  </div>
</div>

<script>
(function() {
  var canvas = document.getElementById('network-canvas');
  var ctx = canvas.getContext('2d');

  function resize() {
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;
  }
  resize();
  window.addEventListener('resize', resize);

  var COLORS = ['#667eea','#764ba2','#f093fb','#4facfe','#43e97b','#fa709a','#30cfd0','#fda085','#a18cd1','#fccb90'];
  var MAX_DIST = 210;
  var nodes = [];
  var particles = [];
  var frame = 0;

  function hexRgba(hex, a) {
    var r = parseInt(hex.slice(1,3),16), g = parseInt(hex.slice(3,5),16), b = parseInt(hex.slice(5,7),16);
    return 'rgba('+r+','+g+','+b+','+a+')';
  }

  for (var i = 0; i < 32; i++) {
    nodes.push({
      x: Math.random() * window.innerWidth,
      y: Math.random() * window.innerHeight,
      vx: (Math.random()-0.5)*0.35,
      vy: (Math.random()-0.5)*0.35,
      r: 13 + Math.random()*10,
      color: COLORS[i % COLORS.length],
      pulse: Math.random()*Math.PI*2,
      ps: 0.012 + Math.random()*0.02,
      ring: 0
    });
  }

  function drawPerson(n) {
    var x=n.x, y=n.y, r=n.r;
    var p = Math.sin(n.pulse)*0.2+0.8;

    // outer glow halo
    var grd = ctx.createRadialGradient(x,y,r*0.3,x,y,r*3.2*p);
    grd.addColorStop(0, hexRgba(n.color, 0.28*p));
    grd.addColorStop(0.5, hexRgba(n.color, 0.1*p));
    grd.addColorStop(1, hexRgba(n.color, 0));
    ctx.beginPath(); ctx.arc(x,y,r*3.2*p,0,Math.PI*2);
    ctx.fillStyle=grd; ctx.fill();

    // ring pulse (connection event)
    if (n.ring > 0) {
      ctx.beginPath();
      ctx.arc(x,y,r+n.ring*40,0,Math.PI*2);
      ctx.strokeStyle = hexRgba(n.color, (1-n.ring)*0.6);
      ctx.lineWidth = 1.5;
      ctx.stroke();
      n.ring -= 0.02;
      if (n.ring < 0) n.ring = 0;
    }

    // head circle
    ctx.beginPath();
    ctx.arc(x, y-r*0.22, r*0.48, 0, Math.PI*2);
    ctx.fillStyle = n.color; ctx.fill();

    // body / shoulders arc
    ctx.beginPath();
    ctx.arc(x, y+r*0.55, r*0.65, Math.PI, 0);
    ctx.fillStyle = n.color; ctx.fill();

    // circle border
    ctx.beginPath();
    ctx.arc(x,y,r,0,Math.PI*2);
    ctx.strokeStyle = hexRgba(n.color,0.6);
    ctx.lineWidth=1.8; ctx.stroke();

    // shine spot
    ctx.beginPath();
    ctx.arc(x-r*0.14, y-r*0.38, r*0.14, 0, Math.PI*2);
    ctx.fillStyle='rgba(255,255,255,0.55)'; ctx.fill();
  }

  function spawnParticle(ai, bi) {
    var dir = Math.random()<0.5;
    particles.push({ ai: dir?ai:bi, bi: dir?bi:ai, prog:0, speed:0.005+Math.random()*0.01, color:nodes[ai].color });
  }

  function draw() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    frame++;

    // connections
    for (var i=0;i<nodes.length;i++) {
      for (var j=i+1;j<nodes.length;j++) {
        var dx=nodes[i].x-nodes[j].x, dy=nodes[i].y-nodes[j].y;
        var dist=Math.sqrt(dx*dx+dy*dy);
        if (dist<MAX_DIST) {
          var a=(1-dist/MAX_DIST)*0.55;
          var gr=ctx.createLinearGradient(nodes[i].x,nodes[i].y,nodes[j].x,nodes[j].y);
          gr.addColorStop(0, hexRgba(nodes[i].color,a));
          gr.addColorStop(1, hexRgba(nodes[j].color,a));
          ctx.beginPath(); ctx.moveTo(nodes[i].x,nodes[i].y); ctx.lineTo(nodes[j].x,nodes[j].y);
          ctx.strokeStyle=gr; ctx.lineWidth=0.9+(1-dist/MAX_DIST)*1.2; ctx.stroke();

          if (frame % 55 === 0 && Math.random()<0.18) {
            spawnParticle(i,j);
            nodes[i].ring = Math.max(nodes[i].ring, 0.01);
            nodes[j].ring = Math.max(nodes[j].ring, 0.01);
          }
        }
      }
    }

    // particles (data pulses)
    for (var k=particles.length-1;k>=0;k--) {
      var p=particles[k];
      p.prog+=p.speed;
      if (p.prog>1){particles.splice(k,1);continue;}
      var na=nodes[p.ai],nb=nodes[p.bi];
      var px=na.x+(nb.x-na.x)*p.prog;
      var py=na.y+(nb.y-na.y)*p.prog;

      // glow
      var pg=ctx.createRadialGradient(px,py,0,px,py,6);
      pg.addColorStop(0,hexRgba(p.color,1));
      pg.addColorStop(1,hexRgba(p.color,0));
      ctx.beginPath(); ctx.arc(px,py,6,0,Math.PI*2);
      ctx.fillStyle=pg; ctx.fill();
      // bright core
      ctx.beginPath(); ctx.arc(px,py,2.2,0,Math.PI*2);
      ctx.fillStyle='rgba(255,255,255,0.95)'; ctx.fill();
    }

    // nodes
    for (var i=0;i<nodes.length;i++) {
      var n=nodes[i];
      n.pulse+=n.ps;
      drawPerson(n);
      n.x+=n.vx; n.y+=n.vy;
      if (n.x<-20||n.x>canvas.width+20) n.vx*=-1;
      if (n.y<-20||n.y>canvas.height+20) n.vy*=-1;
    }

    requestAnimationFrame(draw);
  }
  draw();
})();
</script>
</body>
</html>
