<% page_title "Renewal Details" %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="mb-1">Renewal Details</h2>
    <p class="text-muted mb-0">Membership Renewal Information</p>
  </div>
  <div class="d-flex gap-2">
    <%= link_to edit_admin_membership_renewal_path(@membership_renewal), class: "btn btn-primary" do %>
      <i class="bi bi-pencil me-1"></i>Edit
    <% end %>
    <%= link_to admin_membership_renewals_path, class: "btn btn-outline-secondary" do %>
      <i class="bi bi-arrow-left me-1"></i>Back
    <% end %>
  </div>
</div>

<div class="card border-0 shadow-sm">
  <div class="card-header bg-transparent border-0">
    <h5 class="mb-0">Details</h5>
  </div>
  <div class="card-body">
    <div class="row">
      <div class="col-md-6 mb-3"><div class="text-muted small">Member</div><div class="fw-medium"><%= display_attr(@membership_renewal, :member_id) %></div></div>
      <div class="col-md-6 mb-3"><div class="text-muted small">Plan</div><div class="fw-medium"><%= display_attr(@membership_renewal, :plan_id) %></div></div>
      <div class="col-md-6 mb-3"><div class="text-muted small">Renewal Date</div><div class="fw-medium"><%= display_attr(@membership_renewal, :renewal_date) %></div></div>
      <div class="col-md-6 mb-3"><div class="text-muted small">Expiry Date</div><div class="fw-medium"><%= display_attr(@membership_renewal, :expiry_date) %></div></div>
      <div class="col-md-6 mb-3"><div class="text-muted small">Amount</div><div class="fw-medium"><%= display_attr(@membership_renewal, :amount) %></div></div>
      <div class="col-md-6 mb-3"><div class="text-muted small">Payment Status</div><div class="fw-medium"><%= display_attr(@membership_renewal, :payment_status) %></div></div>
      <div class="col-md-6 mb-3"><div class="text-muted small">Notes</div><div class="fw-medium"><%= display_attr(@membership_renewal, :notes) %></div></div>
    </div>
  </div>
</div>
