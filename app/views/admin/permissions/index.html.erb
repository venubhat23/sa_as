<% page_title "Permissions" %>

<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="mb-1">Permission Matrix</h2>
    <p class="text-muted mb-0">Manage role permissions here</p>
  </div>
</div>

<!-- Role Select Card -->
<div class="card border-0 shadow-sm mb-4">
  <div class="card-body">
    <label class="form-label fw-semibold">Select Role</label>
    <select id="roleSelect" class="form-select" style="max-width:300px;">
      <% @roles.each do |role| %><option value="<%= role.id %>"><%= role.name %></option><% end %>
    </select>
  </div>
</div>

<!-- Permissions Table Card -->
<div class="card border-0 shadow-sm">
  <div class="card-header bg-transparent border-0">
    <h5 class="mb-0">Module Permissions</h5>
  </div>
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-bordered align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th class="border-0 fw-semibold">Module</th>
            <th class="border-0 fw-semibold text-center">View</th>
            <th class="border-0 fw-semibold text-center">Create</th>
            <th class="border-0 fw-semibold text-center">Edit</th>
            <th class="border-0 fw-semibold text-center">Delete</th>
            <th class="border-0 fw-semibold text-center">Export</th>
          </tr>
        </thead>
        <tbody>
          <% @modules.each do |mod| %>
            <tr data-module="<%= mod %>">
              <td class="fw-medium"><%= mod %></td>
              <% %w[view create edit delete export].each do |act| %>
                <td class="text-center">
                  <input type="checkbox" class="form-check-input perm-checkbox" data-action="can_<%= act %>" data-module="<%= mod %>">
                </td>
              <% end %>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<script>
  (function() {
    const permData = <%= raw @permissions.map { |k, v| [k.join("|"), { can_view: v.can_view, can_create: v.can_create, can_edit: v.can_edit, can_delete: v.can_delete, can_export: v.can_export }] }.to_h.to_json %>;
    const csrf = document.querySelector('meta[name="csrf-token"]')?.content;

    function loadRole(roleId) {
      document.querySelectorAll('tr[data-module]').forEach(row => {
        const mod = row.dataset.module;
        const data = permData[roleId + "|" + mod] || {};
        row.querySelectorAll('.perm-checkbox').forEach(cb => {
          cb.checked = !!data[cb.dataset.action];
        });
      });
    }

    function currentState(mod) {
      const row = document.querySelector(`tr[data-module="${mod}"]`);
      const state = {};
      row.querySelectorAll('.perm-checkbox').forEach(cb => { state[cb.dataset.action] = cb.checked; });
      return state;
    }

    document.addEventListener('change', function(e) {
      if (!e.target.classList.contains('perm-checkbox')) return;
      const roleId = document.getElementById('roleSelect').value;
      const mod = e.target.dataset.module;
      const st = currentState(mod);
      fetch(`/admin/permissions/${roleId}.json`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrf },
        body: JSON.stringify({ module_name: mod, can_view: ''+st.can_view, can_create: ''+st.can_create, can_edit: ''+st.can_edit, can_delete: ''+st.can_delete, can_export: ''+st.can_export })
      }).then(() => { permData[roleId + "|" + mod] = st; });
    });

    const sel = document.getElementById('roleSelect');
    if (sel) { sel.addEventListener('change', () => loadRole(sel.value)); loadRole(sel.value); }
  })();
</script>
