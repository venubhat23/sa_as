<% page_title @member.full_name %>

<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="mb-1"><%= @member.full_name %> <%= status_badge(@member.membership_status) %></h2>
    <p class="text-muted mb-0">Member Details</p>
  </div>
  <div class="d-flex gap-2">
    <%= link_to edit_admin_member_path(@member), class: "btn btn-primary" do %>
      <i class="bi bi-pencil me-1"></i>Edit
    <% end %>
    <%= link_to admin_members_path, class: "btn btn-outline-secondary" do %>
      <i class="bi bi-arrow-left me-1"></i>Back
    <% end %>
  </div>
</div>

<div class="card border-0 shadow-sm">
  <div class="card-header bg-transparent border-0">
    <h5 class="mb-0">Details</h5>
  </div>
  <div class="card-body">
    <ul class="nav nav-tabs mb-3" role="tablist">
      <li class="nav-item"><button class="nav-link active" data-bs-toggle="tab" data-bs-target="#basic">Basic Information</button></li>
      <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#business">Business Information</button></li>
      <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#membership">Membership Information</button></li>
      <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#kyc">KYC Documents</button></li>
      <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#referrals">Referral History</button></li>
      <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#attendance">Attendance History</button></li>
    </ul>

    <div class="tab-content">
      <div class="tab-pane fade show active" id="basic">
        <div class="row">
          <div class="col-md-4 mb-3"><div class="text-muted small">Membership #</div><div class="fw-medium"><%= display_attr(@member, :membership_number) %></div></div>
          <div class="col-md-4 mb-3"><div class="text-muted small">Phone</div><div class="fw-medium"><%= display_attr(@member, :phone) %></div></div>
          <div class="col-md-4 mb-3"><div class="text-muted small">Email</div><div class="fw-medium"><%= display_attr(@member, :email) %></div></div>
          <div class="col-md-4 mb-3"><div class="text-muted small">Date of Birth</div><div class="fw-medium"><%= display_attr(@member, :dob) %></div></div>
          <div class="col-md-8 mb-3"><div class="text-muted small">Address</div><div class="fw-medium"><%= display_attr(@member, :address) %></div></div>
          <div class="col-md-4 mb-3"><div class="text-muted small">City</div><div class="fw-medium"><%= display_attr(@member, :city) %></div></div>
          <div class="col-md-4 mb-3"><div class="text-muted small">State</div><div class="fw-medium"><%= display_attr(@member, :state) %></div></div>
          <div class="col-md-4 mb-3"><div class="text-muted small">Pincode</div><div class="fw-medium"><%= display_attr(@member, :pincode) %></div></div>
        </div>
      </div>

      <div class="tab-pane fade" id="business">
        <div class="row">
          <div class="col-md-6 mb-3"><div class="text-muted small">Company</div><div class="fw-medium"><%= display_attr(@member, :company_name) %></div></div>
          <div class="col-md-3 mb-3"><div class="text-muted small">GST Number</div><div class="fw-medium"><%= display_attr(@member, :gst_number) %></div></div>
          <div class="col-md-3 mb-3"><div class="text-muted small">PAN Number</div><div class="fw-medium"><%= display_attr(@member, :pan_number) %></div></div>
          <div class="col-md-6 mb-3"><div class="text-muted small">Category</div><div class="fw-medium"><%= @member.business_category&.name || "—" %></div></div>
          <div class="col-md-6 mb-3"><div class="text-muted small">Specialty</div><div class="fw-medium"><%= @member.business_specialty&.name || "—" %></div></div>
          <div class="col-md-6 mb-3"><div class="text-muted small">Website</div><div class="fw-medium"><%= display_attr(@member, :website) %></div></div>
          <div class="col-md-6 mb-3"><div class="text-muted small">LinkedIn</div><div class="fw-medium"><%= display_attr(@member, :linkedin_url) %></div></div>
        </div>
      </div>

      <div class="tab-pane fade" id="membership">
        <div class="row">
          <div class="col-md-4 mb-3"><div class="text-muted small">Forum</div><div class="fw-medium"><%= @member.forum&.name || "—" %></div></div>
          <div class="col-md-4 mb-3"><div class="text-muted small">Chapter</div><div class="fw-medium"><%= @member.chapter&.name || "—" %></div></div>
          <div class="col-md-4 mb-3"><div class="text-muted small">Plan</div><div class="fw-medium"><%= @member.membership_plan&.name || "—" %></div></div>
          <div class="col-md-4 mb-3"><div class="text-muted small">Joining Date</div><div class="fw-medium"><%= display_attr(@member, :joining_date) %></div></div>
          <div class="col-md-4 mb-3"><div class="text-muted small">Renewal Date</div><div class="fw-medium"><%= display_attr(@member, :renewal_date) %></div></div>
          <div class="col-md-4 mb-3"><div class="text-muted small">Status</div><div class="fw-medium"><%= status_badge(@member.membership_status) %></div></div>
        </div>
      </div>

      <div class="tab-pane fade" id="kyc">
        <div class="row">
          <div class="col-md-6 mb-3"><div class="text-muted small">PAN Document</div><div class="fw-medium"><%= display_attr(@member, :pan_document) %></div></div>
          <div class="col-md-6 mb-3"><div class="text-muted small">GST Document</div><div class="fw-medium"><%= display_attr(@member, :gst_document) %></div></div>
          <div class="col-md-6 mb-3"><div class="text-muted small">Aadhar Document</div><div class="fw-medium"><%= display_attr(@member, :aadhar_document) %></div></div>
          <div class="col-md-6 mb-3"><div class="text-muted small">Business Registration</div><div class="fw-medium"><%= display_attr(@member, :business_registration_document) %></div></div>
        </div>
      </div>

      <div class="tab-pane fade" id="referrals">
        <h6 class="text-muted">Referrals Given</h6>
        <table class="table table-sm"><thead><tr><th>Ref #</th><th>Client</th><th>Value</th><th>Status</th></tr></thead><tbody>
          <% @member.referrals_given.each do |r| %><tr><td><%= r.referral_number %></td><td><%= r.client_name %></td><td><%= inr(r.referral_value) %></td><td><%= workflow_badge(r.workflow_status) %></td></tr><% end %>
          <% if @member.referrals_given.empty? %><tr><td colspan="4" class="text-muted">None.</td></tr><% end %>
        </tbody></table>
        <h6 class="text-muted mt-3">Referrals Received</h6>
        <table class="table table-sm"><thead><tr><th>Ref #</th><th>Client</th><th>Value</th><th>Status</th></tr></thead><tbody>
          <% @member.referrals_received.each do |r| %><tr><td><%= r.referral_number %></td><td><%= r.client_name %></td><td><%= inr(r.referral_value) %></td><td><%= workflow_badge(r.workflow_status) %></td></tr><% end %>
          <% if @member.referrals_received.empty? %><tr><td colspan="4" class="text-muted">None.</td></tr><% end %>
        </tbody></table>
      </div>

      <div class="tab-pane fade" id="attendance">
        <table class="table table-sm"><thead><tr><th>Meeting Date</th><th>Type</th><th>Status</th></tr></thead><tbody>
          <% @member.meeting_attendances.includes(:weekly_meeting).each do |a| %>
            <tr><td><%= a.weekly_meeting&.meeting_date %></td><td><%= a.weekly_meeting&.meeting_type %></td><td><%= status_badge(a.attendance_status) %></td></tr>
          <% end %>
          <% if @member.meeting_attendances.empty? %><tr><td colspan="3" class="text-muted">No attendance records.</td></tr><% end %>
        </tbody></table>
      </div>
    </div>
  </div>
</div>
