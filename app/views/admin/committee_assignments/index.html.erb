<% page_title "Committee Assignments" %>

<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="mb-1">Committee Assignment Management</h2>
    <p class="text-muted mb-0">Manage your committee assignments here</p>
  </div>
  <div>
    <%= link_to new_admin_committee_assignment_path, class: "btn btn-primary" do %>
      <i class="bi bi-plus-lg me-1"></i> Add New Committee Assignment
    <% end %>
  </div>
</div>

<!-- Table Card -->
<div class="card border-0 shadow-sm">
  <div class="card-header bg-transparent border-0">
    <h5 class="mb-0">Committee Assignment List</h5>
  </div>
  <div class="card-body p-0">
    <% if @committee_assignments.any? %>
      <div class="table-responsive">
        <table class="table table-hover mb-0">
          <thead class="table-light">
            <tr>
              <th class="border-0 fw-semibold">Member</th>
              <th class="border-0 fw-semibold">Role</th>
              <th class="border-0 fw-semibold">Chapter</th>
              <th class="border-0 fw-semibold">Start</th>
              <th class="border-0 fw-semibold">End</th>
              <th class="border-0 fw-semibold">Status</th>
              <th class="border-0 fw-semibold">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% @committee_assignments.each do |f| %>
              <tr>
                <td class="align-middle"><%= f.member&.full_name %></td>
                <td class="align-middle"><%= f.committee_role&.name %></td>
                <td class="align-middle"><%= f.chapter&.name %></td>
                <td class="align-middle"><%= f.start_date %></td>
                <td class="align-middle"><%= f.end_date %></td>
                <td class="align-middle"><%= status_badge(f.status) %></td>
                <td class="align-middle">
                  <div class="dropdown">
                    <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown">
                      <i class="bi bi-three-dots"></i>
                    </button>
                    <ul class="dropdown-menu">
                      <li><%= link_to admin_committee_assignment_path(f), class: "dropdown-item" do %><i class="bi bi-eye me-2"></i>View<% end %></li>
                      <li><%= link_to edit_admin_committee_assignment_path(f), class: "dropdown-item" do %><i class="bi bi-pencil me-2"></i>Edit<% end %></li>
                      <li><hr class="dropdown-divider"></li>
                      <li><%= link_to admin_committee_assignment_path(f), data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "dropdown-item text-danger" do %><i class="bi bi-trash me-2"></i>Delete<% end %></li>
                    </ul>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      <div class="card-footer bg-transparent border-0">
        <%= paginate @committee_assignments if @committee_assignments.respond_to?(:current_page) %>
      </div>
    <% else %>
      <div class="text-center py-5">
        <i class="bi bi-person-check-fill fs-1 text-muted mb-3 d-block"></i>
        <h5 class="text-muted mb-3">No Committee Assignments Found</h5>
        <p class="text-muted mb-4">Get started by adding your first committee assignment.</p>
        <%= link_to "Add Committee Assignment", new_admin_committee_assignment_path, class: "btn btn-primary" %>
      </div>
    <% end %>
  </div>
</div>
