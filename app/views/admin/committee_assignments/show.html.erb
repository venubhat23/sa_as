<% page_title "Committee Assignment Details" %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="mb-1">Committee Assignment Details</h2>
    <p class="text-muted mb-0">Assignment Information</p>
  </div>
  <div class="d-flex gap-2">
    <%= link_to edit_admin_committee_assignment_path(@committee_assignment), class: "btn btn-primary" do %>
      <i class="bi bi-pencil me-1"></i>Edit
    <% end %>
    <%= link_to admin_committee_assignments_path, class: "btn btn-outline-secondary" do %>
      <i class="bi bi-arrow-left me-1"></i>Back
    <% end %>
  </div>
</div>

<div class="card border-0 shadow-sm">
  <div class="card-header bg-transparent border-0">
    <h5 class="mb-0">Details</h5>
  </div>
  <div class="card-body">
    <div class="row">
      <div class="col-md-6 mb-3"><div class="text-muted small">Member</div><div class="fw-medium"><%= display_attr(@committee_assignment, :member_id) %></div></div>
      <div class="col-md-6 mb-3"><div class="text-muted small">Committee Role</div><div class="fw-medium"><%= display_attr(@committee_assignment, :committee_role_id) %></div></div>
      <div class="col-md-6 mb-3"><div class="text-muted small">Chapter</div><div class="fw-medium"><%= display_attr(@committee_assignment, :chapter_id) %></div></div>
      <div class="col-md-6 mb-3"><div class="text-muted small">Start Date</div><div class="fw-medium"><%= display_attr(@committee_assignment, :start_date) %></div></div>
      <div class="col-md-6 mb-3"><div class="text-muted small">End Date</div><div class="fw-medium"><%= display_attr(@committee_assignment, :end_date) %></div></div>
      <div class="col-md-6 mb-3"><div class="text-muted small">Status</div><div class="fw-medium"><%= display_attr(@committee_assignment, :status) %></div></div>
    </div>
  </div>
</div>
