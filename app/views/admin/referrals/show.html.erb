<% page_title @referral.referral_number %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="mb-1"><%= @referral.referral_number %> <%= workflow_badge(@referral.workflow_status) %></h2>
    <p class="text-muted mb-0">Referral Details</p>
  </div>
  <div class="d-flex gap-2">
    <%= link_to edit_admin_referral_path(@referral), class: "btn btn-primary" do %>
      <i class="bi bi-pencil me-1"></i>Edit
    <% end %>
    <%= link_to admin_referrals_path, class: "btn btn-outline-secondary" do %>
      <i class="bi bi-arrow-left me-1"></i>Back
    <% end %>
  </div>
</div>

<div class="card border-0 shadow-sm mb-4">
  <div class="card-header bg-transparent border-0">
    <h5 class="mb-0">Details</h5>
  </div>
  <div class="card-body">
    <div class="row">
      <div class="col-md-4 mb-3"><div class="text-muted small">Date</div><div class="fw-medium"><%= display_attr(@referral, :referral_date) %></div></div>
      <div class="col-md-4 mb-3"><div class="text-muted small">Given By</div><div class="fw-medium"><%= @referral.given_by_member&.full_name || "—" %></div></div>
      <div class="col-md-4 mb-3"><div class="text-muted small">Given To</div><div class="fw-medium"><%= @referral.given_to_member&.full_name || "—" %></div></div>
      <div class="col-md-4 mb-3"><div class="text-muted small">Client</div><div class="fw-medium"><%= display_attr(@referral, :client_name) %></div></div>
      <div class="col-md-4 mb-3"><div class="text-muted small">Client Phone</div><div class="fw-medium"><%= display_attr(@referral, :client_phone) %></div></div>
      <div class="col-md-4 mb-3"><div class="text-muted small">Value</div><div class="fw-medium"><%= inr(@referral.referral_value) %></div></div>
      <div class="col-md-12 mb-3"><div class="text-muted small">Notes</div><div class="fw-medium"><%= display_attr(@referral, :notes) %></div></div>
    </div>
  </div>
</div>

<div class="card border-0 shadow-sm">
  <div class="card-header bg-transparent border-0">
    <h5 class="mb-0">Update Workflow Status</h5>
  </div>
  <div class="card-body">
    <%= form_with url: update_workflow_admin_referral_path(@referral), method: :patch, local: true do |f| %>
      <div class="d-flex gap-2" style="max-width:400px;">
        <%= f.select :workflow_status, Referral.workflow_statuses.keys, { selected: @referral.workflow_status }, class: "form-select" %>
        <%= f.submit "Update", class: "btn btn-primary" %>
      </div>
    <% end %>
  </div>
</div>
