<% page_title "Referrals" %>

<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="mb-1">Referral Management</h2>
    <p class="text-muted mb-0">Manage your referrals here</p>
  </div>
  <div class="d-flex gap-2">
    <%= link_to pipeline_admin_referrals_path, class: "btn btn-outline-secondary" do %>
      <i class="bi bi-kanban me-1"></i>Pipeline
    <% end %>
    <%= link_to new_admin_referral_path, class: "btn btn-primary" do %>
      <i class="bi bi-plus-lg me-1"></i> Add New Referral
    <% end %>
  </div>
</div>

<!-- Stats Cards -->
<div class="row mb-4">
  <div class="col-md-3">
    <div class="card border-0 shadow-sm">
      <div class="card-body">
        <div class="d-flex align-items-center">
          <div class="flex-grow-1">
            <h6 class="text-muted mb-1">Total Referral Value</h6>
            <h4 class="mb-0"><%= inr(@total_value) %></h4>
          </div>
          <div class="text-primary"><i class="bi bi-share-fill fs-2"></i></div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card border-0 shadow-sm">
      <div class="card-body">
        <div class="d-flex align-items-center">
          <div class="flex-grow-1">
            <h6 class="text-muted mb-1">Won Referrals</h6>
            <h4 class="mb-0"><%= @won_count %></h4>
          </div>
          <div class="text-success"><i class="bi bi-trophy-fill fs-2"></i></div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Filter Card -->
<div class="card border-0 shadow-sm mb-4">
  <div class="card-body">
    <%= form_with url: admin_referrals_path, method: :get, local: true do |f| %>
      <div class="row g-2 align-items-end">
        <div class="col-md-4">
          <%= f.label :workflow_status, "Workflow Status", class: "form-label" %>
          <%= f.select :workflow_status, Referral.workflow_statuses.keys, { include_blank: "All", selected: params[:workflow_status] }, class: "form-select" %>
        </div>
        <div class="col-md-4">
          <%= f.submit "Filter", class: "btn btn-primary" %>
          <%= link_to "Reset", admin_referrals_path, class: "btn btn-outline-secondary ms-1" %>
        </div>
      </div>
    <% end %>
  </div>
</div>

<!-- Table Card -->
<div class="card border-0 shadow-sm">
  <div class="card-header bg-transparent border-0">
    <h5 class="mb-0">Referral List</h5>
  </div>
  <div class="card-body p-0">
    <% if @referrals.any? %>
      <div class="table-responsive">
        <table class="table table-hover mb-0">
          <thead class="table-light">
            <tr>
              <th class="border-0 fw-semibold">Ref #</th>
              <th class="border-0 fw-semibold">Date</th>
              <th class="border-0 fw-semibold">Given By</th>
              <th class="border-0 fw-semibold">Given To</th>
              <th class="border-0 fw-semibold">Client</th>
              <th class="border-0 fw-semibold">Value</th>
              <th class="border-0 fw-semibold">Status</th>
              <th class="border-0 fw-semibold">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% @referrals.each do |r| %>
              <tr>
                <td class="align-middle"><%= link_to r.referral_number, admin_referral_path(r), class: "fw-medium text-decoration-none" %></td>
                <td class="align-middle"><%= r.referral_date %></td>
                <td class="align-middle"><%= r.given_by_member&.full_name %></td>
                <td class="align-middle"><%= r.given_to_member&.full_name %></td>
                <td class="align-middle"><%= r.client_name %></td>
                <td class="align-middle"><%= inr(r.referral_value) %></td>
                <td class="align-middle"><%= workflow_badge(r.workflow_status) %></td>
                <td class="align-middle">
                  <div class="dropdown">
                    <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown">
                      <i class="bi bi-three-dots"></i>
                    </button>
                    <ul class="dropdown-menu">
                      <li><%= link_to admin_referral_path(r), class: "dropdown-item" do %><i class="bi bi-eye me-2"></i>View<% end %></li>
                      <li><%= link_to edit_admin_referral_path(r), class: "dropdown-item" do %><i class="bi bi-pencil me-2"></i>Edit<% end %></li>
                      <li><hr class="dropdown-divider"></li>
                      <li><%= link_to admin_referral_path(r), data: { turbo_method: :delete, turbo_confirm: "Delete?" }, class: "dropdown-item text-danger" do %><i class="bi bi-trash me-2"></i>Delete<% end %></li>
                    </ul>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      <div class="card-footer bg-transparent border-0">
        <%= paginate @referrals %>
      </div>
    <% else %>
      <div class="text-center py-5">
        <i class="bi bi-share-fill fs-1 text-muted mb-3 d-block"></i>
        <h5 class="text-muted mb-3">No Referrals Found</h5>
        <p class="text-muted mb-4">Get started by adding your first referral.</p>
        <%= link_to "Add Referral", new_admin_referral_path, class: "btn btn-primary" %>
      </div>
    <% end %>
  </div>
</div>
