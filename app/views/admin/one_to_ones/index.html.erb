<% page_title "One-To-One Meetings" %>

<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="mb-1">One-To-One Meeting Management</h2>
    <p class="text-muted mb-0">Manage your one-to-one meetings here</p>
  </div>
  <div>
    <%= link_to new_admin_one_to_one_path, class: "btn btn-primary" do %>
      <i class="bi bi-plus-lg me-1"></i> Add New One-To-One Meeting
    <% end %>
  </div>
</div>

<!-- Table Card -->
<div class="card border-0 shadow-sm">
  <div class="card-header bg-transparent border-0">
    <h5 class="mb-0">One-To-One Meeting List</h5>
  </div>
  <div class="card-body p-0">
    <% if @one_to_ones.any? %>
      <div class="table-responsive">
        <table class="table table-hover mb-0">
          <thead class="table-light">
            <tr>
              <th class="border-0 fw-semibold">Member 1</th>
              <th class="border-0 fw-semibold">Member 2</th>
              <th class="border-0 fw-semibold">Date</th>
              <th class="border-0 fw-semibold">Location</th>
              <th class="border-0 fw-semibold">Status</th>
              <th class="border-0 fw-semibold">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% @one_to_ones.each do |f| %>
              <tr>
                <td class="align-middle"><%= f.member1&.full_name %></td>
                <td class="align-middle"><%= f.member2&.full_name %></td>
                <td class="align-middle"><%= f.meeting_date %></td>
                <td class="align-middle"><%= f.location %></td>
                <td class="align-middle"><%= status_badge(f.status) %></td>
                <td class="align-middle">
                  <div class="dropdown">
                    <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown">
                      <i class="bi bi-three-dots"></i>
                    </button>
                    <ul class="dropdown-menu">
                      <li><%= link_to admin_one_to_one_path(f), class: "dropdown-item" do %><i class="bi bi-eye me-2"></i>View<% end %></li>
                      <li><%= link_to edit_admin_one_to_one_path(f), class: "dropdown-item" do %><i class="bi bi-pencil me-2"></i>Edit<% end %></li>
                      <li><hr class="dropdown-divider"></li>
                      <li><%= link_to admin_one_to_one_path(f), data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "dropdown-item text-danger" do %><i class="bi bi-trash me-2"></i>Delete<% end %></li>
                    </ul>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      <div class="card-footer bg-transparent border-0">
        <%= paginate @one_to_ones if @one_to_ones.respond_to?(:current_page) %>
      </div>
    <% else %>
      <div class="text-center py-5">
        <i class="bi bi-people fs-1 text-muted mb-3 d-block"></i>
        <h5 class="text-muted mb-3">No One-To-One Meetings Found</h5>
        <p class="text-muted mb-4">Get started by adding your first one-to-one meeting.</p>
        <%= link_to "Add One-To-One Meeting", new_admin_one_to_one_path, class: "btn btn-primary" %>
      </div>
    <% end %>
  </div>
</div>
