<% page_title "One-To-One Meeting Details" %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="mb-1">One-To-One Meeting Details</h2>
    <p class="text-muted mb-0">Meeting Information</p>
  </div>
  <div class="d-flex gap-2">
    <%= link_to edit_admin_one_to_one_path(@one_to_one), class: "btn btn-primary" do %>
      <i class="bi bi-pencil me-1"></i>Edit
    <% end %>
    <%= link_to admin_one_to_ones_path, class: "btn btn-outline-secondary" do %>
      <i class="bi bi-arrow-left me-1"></i>Back
    <% end %>
  </div>
</div>

<div class="card border-0 shadow-sm">
  <div class="card-header bg-transparent border-0">
    <h5 class="mb-0">Details</h5>
  </div>
  <div class="card-body">
    <div class="row">
      <div class="col-md-6 mb-3"><div class="text-muted small">Member 1</div><div class="fw-medium"><%= display_attr(@one_to_one, :member1_id) %></div></div>
      <div class="col-md-6 mb-3"><div class="text-muted small">Member 2</div><div class="fw-medium"><%= display_attr(@one_to_one, :member2_id) %></div></div>
      <div class="col-md-6 mb-3"><div class="text-muted small">Meeting Date</div><div class="fw-medium"><%= display_attr(@one_to_one, :meeting_date) %></div></div>
      <div class="col-md-6 mb-3"><div class="text-muted small">Location</div><div class="fw-medium"><%= display_attr(@one_to_one, :location) %></div></div>
      <div class="col-md-6 mb-3"><div class="text-muted small">Agenda</div><div class="fw-medium"><%= display_attr(@one_to_one, :agenda) %></div></div>
      <div class="col-md-6 mb-3"><div class="text-muted small">Discussion Notes</div><div class="fw-medium"><%= display_attr(@one_to_one, :discussion_notes) %></div></div>
      <div class="col-md-6 mb-3"><div class="text-muted small">Action Items</div><div class="fw-medium"><%= display_attr(@one_to_one, :action_items) %></div></div>
      <div class="col-md-6 mb-3"><div class="text-muted small">Status</div><div class="fw-medium"><%= display_attr(@one_to_one, :status) %></div></div>
    </div>
  </div>
</div>
