<% page_title "Weekly Meetings" %>

<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="mb-1">Weekly Meeting Management</h2>
    <p class="text-muted mb-0">Manage your weekly meetings here</p>
  </div>
  <div>
    <%= link_to new_admin_weekly_meeting_path, class: "btn btn-primary" do %>
      <i class="bi bi-plus-lg me-1"></i> Add New Meeting
    <% end %>
  </div>
</div>

<!-- Table Card -->
<div class="card border-0 shadow-sm">
  <div class="card-header bg-transparent border-0">
    <h5 class="mb-0">Meeting List</h5>
  </div>
  <div class="card-body p-0">
    <% if @weekly_meetings.any? %>
      <div class="table-responsive">
        <table class="table table-hover mb-0">
          <thead class="table-light">
            <tr>
              <th class="border-0 fw-semibold">Date</th>
              <th class="border-0 fw-semibold">Type</th>
              <th class="border-0 fw-semibold">Chapter</th>
              <th class="border-0 fw-semibold">Venue</th>
              <th class="border-0 fw-semibold">Status</th>
              <th class="border-0 fw-semibold">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% @weekly_meetings.each do |m| %>
              <tr>
                <td class="align-middle"><%= link_to m.meeting_date, admin_weekly_meeting_path(m), class: "fw-medium text-decoration-none" %></td>
                <td class="align-middle"><%= m.meeting_type %></td>
                <td class="align-middle"><%= m.chapter&.name %></td>
                <td class="align-middle"><%= m.venue %></td>
                <td class="align-middle"><%= status_badge(m.status) %></td>
                <td class="align-middle">
                  <div class="dropdown">
                    <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown">
                      <i class="bi bi-three-dots"></i>
                    </button>
                    <ul class="dropdown-menu">
                      <li><%= link_to admin_weekly_meeting_path(m), class: "dropdown-item" do %><i class="bi bi-eye me-2"></i>View<% end %></li>
                      <li><%= link_to edit_admin_weekly_meeting_path(m), class: "dropdown-item" do %><i class="bi bi-pencil me-2"></i>Edit<% end %></li>
                      <li><hr class="dropdown-divider"></li>
                      <li><%= link_to admin_weekly_meeting_path(m), data: { turbo_method: :delete, turbo_confirm: "Delete?" }, class: "dropdown-item text-danger" do %><i class="bi bi-trash me-2"></i>Delete<% end %></li>
                    </ul>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      <div class="card-footer bg-transparent border-0">
        <%= paginate @weekly_meetings %>
      </div>
    <% else %>
      <div class="text-center py-5">
        <i class="bi bi-calendar-check-fill fs-1 text-muted mb-3 d-block"></i>
        <h5 class="text-muted mb-3">No Meetings Found</h5>
        <p class="text-muted mb-4">Get started by adding your first meeting.</p>
        <%= link_to "Add Meeting", new_admin_weekly_meeting_path, class: "btn btn-primary" %>
      </div>
    <% end %>
  </div>
</div>
