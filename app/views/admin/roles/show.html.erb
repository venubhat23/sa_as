<% page_title @role.name %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="mb-1"><%= @role.name %></h2>
    <p class="text-muted mb-0">Role Details</p>
  </div>
  <div class="d-flex gap-2">
    <%= link_to edit_admin_role_path(@role), class: "btn btn-primary" do %>
      <i class="bi bi-pencil me-1"></i>Edit
    <% end %>
    <%= link_to admin_roles_path, class: "btn btn-outline-secondary" do %>
      <i class="bi bi-arrow-left me-1"></i>Back
    <% end %>
  </div>
</div>

<div class="card border-0 shadow-sm">
  <div class="card-header bg-transparent border-0">
    <h5 class="mb-0">Details</h5>
  </div>
  <div class="card-body">
    <div class="row">
      <div class="col-md-6 mb-3"><div class="text-muted small">Description</div><div class="fw-medium"><%= display_attr(@role, :description) %></div></div>
      <div class="col-md-3 mb-3"><div class="text-muted small">Status</div><div><%= status_badge(@role.status) %></div></div>
      <div class="col-md-3 mb-3"><div class="text-muted small">Users</div><div class="fw-medium"><%= @role.users.count %></div></div>
    </div>
    <h6 class="mt-3 text-muted">Module Permissions</h6>
    <table class="table table-sm">
      <thead>
        <tr>
          <th>Module</th>
          <th>View</th>
          <th>Create</th>
          <th>Edit</th>
          <th>Delete</th>
          <th>Export</th>
        </tr>
      </thead>
      <tbody>
        <% @role.permissions.each do |p| %>
          <tr>
            <td><%= p.module_name %></td>
            <td><%= p.can_view ? "✓" : "—" %></td>
            <td><%= p.can_create ? "✓" : "—" %></td>
            <td><%= p.can_edit ? "✓" : "—" %></td>
            <td><%= p.can_delete ? "✓" : "—" %></td>
            <td><%= p.can_export ? "✓" : "—" %></td>
          </tr>
        <% end %>
        <% if @role.permissions.empty? %>
          <tr><td colspan="6" class="text-muted">No permissions set.</td></tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
