<%= form_with model: [:admin, @role], local: true do |form| %>
  <% if @role.errors.any? %><div class="alert alert-danger"><ul class="mb-0"><% @role.errors.full_messages.each do |m| %><li><%= m %></li><% end %></ul></div><% end %>
  <div class="row">
    <div class="col-md-6 mb-3"><%= form.label :name, class: "form-label" %><%= form.text_field :name, class: "form-control" %></div>
    <div class="col-md-6 mb-3"><%= form.label :status, class: "form-label" %><%= form.select :status, %w[active inactive], {}, class: "form-select" %></div>
    <div class="col-md-12 mb-3"><%= form.label :description, class: "form-label" %><%= form.text_area :description, rows: 3, class: "form-control" %></div>
    <div class="col-md-12 mb-3 form-check ms-2"><%= form.check_box :is_system_role, class: "form-check-input" %><%= form.label :is_system_role, "System Role", class: "form-check-label ms-1" %></div>
  </div>
  <div class="mt-3"><%= form.submit "Save", class: "btn btn-primary" %> <%= link_to "Cancel", admin_roles_path, class: "btn btn-light" %></div>
<% end %>
