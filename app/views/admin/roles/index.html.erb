<% page_title "Roles" %>

<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="mb-1">Role Management</h2>
    <p class="text-muted mb-0">Manage your roles here</p>
  </div>
  <div>
    <%= link_to new_admin_role_path, class: "btn btn-primary" do %>
      <i class="bi bi-plus-lg me-1"></i> Add New Role
    <% end %>
  </div>
</div>

<!-- Table Card -->
<div class="card border-0 shadow-sm">
  <div class="card-header bg-transparent border-0">
    <h5 class="mb-0">Role List</h5>
  </div>
  <div class="card-body p-0">
    <% if @roles.any? %>
      <div class="table-responsive">
        <table class="table table-hover mb-0">
          <thead class="table-light">
            <tr>
              <th class="border-0 fw-semibold">Name</th>
              <th class="border-0 fw-semibold">Description</th>
              <th class="border-0 fw-semibold">System</th>
              <th class="border-0 fw-semibold">Status</th>
              <th class="border-0 fw-semibold">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% @roles.each do |r| %>
              <tr>
                <td class="align-middle"><%= link_to r.name, admin_role_path(r), class: "fw-medium text-decoration-none" %></td>
                <td class="align-middle"><%= truncate(r.description.to_s, length: 60) %></td>
                <td class="align-middle"><%= r.is_system_role ? content_tag(:span, "System", class: "badge bg-dark") : "—" %></td>
                <td class="align-middle"><%= status_badge(r.status) %></td>
                <td class="align-middle">
                  <div class="dropdown">
                    <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown">
                      <i class="bi bi-three-dots"></i>
                    </button>
                    <ul class="dropdown-menu">
                      <li><%= link_to admin_role_path(r), class: "dropdown-item" do %><i class="bi bi-eye me-2"></i>View<% end %></li>
                      <li><%= link_to edit_admin_role_path(r), class: "dropdown-item" do %><i class="bi bi-pencil me-2"></i>Edit<% end %></li>
                      <li><%= link_to clone_admin_role_path(r), data: { turbo_method: :post }, class: "dropdown-item" do %><i class="bi bi-files me-2"></i>Clone<% end %></li>
                      <% unless r.is_system_role %>
                        <li><hr class="dropdown-divider"></li>
                        <li><%= link_to admin_role_path(r), data: { turbo_method: :delete, turbo_confirm: "Delete?" }, class: "dropdown-item text-danger" do %><i class="bi bi-trash me-2"></i>Delete<% end %></li>
                      <% end %>
                    </ul>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      <div class="card-footer bg-transparent border-0">
        <%= paginate @roles %>
      </div>
    <% else %>
      <div class="text-center py-5">
        <i class="bi bi-shield-fill fs-1 text-muted mb-3 d-block"></i>
        <h5 class="text-muted mb-3">No Roles Found</h5>
        <p class="text-muted mb-4">Get started by adding your first role.</p>
        <%= link_to "Add Role", new_admin_role_path, class: "btn btn-primary" %>
      </div>
    <% end %>
  </div>
</div>
