<%= form_with model: [:admin, :settings, @referral_rule], local: true do |form| %>
  <% if @referral_rule.errors.any? %><div class="alert alert-danger"><ul class="mb-0"><% @referral_rule.errors.full_messages.each do |m| %><li><%= m %></li><% end %></ul></div><% end %>
  <div class="row">
    <div class="col-md-6 mb-3"><%= form.label :rule_type, class: "form-label" %><%= form.text_field :rule_type, class: "form-control" %></div>
    <div class="col-md-6 mb-3"><%= form.label :value, class: "form-label" %><%= form.text_field :value, class: "form-control" %></div>
    <div class="col-md-12 mb-3"><%= form.label :description, class: "form-label" %><%= form.text_area :description, rows: 2, class: "form-control" %></div>
    <div class="col-md-6 mb-3"><%= form.label :status, class: "form-label" %><%= form.select :status, %w[active inactive], {}, class: "form-select" %></div>
  </div>
  <div class="mt-3"><%= form.submit "Save", class: "btn btn-primary" %> <%= link_to "Cancel", admin_settings_referral_rules_path, class: "btn btn-light" %></div>
<% end %>
