<% page_title "Thank You Slip Details" %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="mb-1">Thank You Slip Details</h2>
    <p class="text-muted mb-0">Thank You Slip Information</p>
  </div>
  <div class="d-flex gap-2">
    <%= link_to edit_admin_thank_you_slip_path(@thank_you_slip), class: "btn btn-primary" do %>
      <i class="bi bi-pencil me-1"></i>Edit
    <% end %>
    <%= link_to admin_thank_you_slips_path, class: "btn btn-outline-secondary" do %>
      <i class="bi bi-arrow-left me-1"></i>Back
    <% end %>
  </div>
</div>

<div class="card border-0 shadow-sm">
  <div class="card-header bg-transparent border-0">
    <h5 class="mb-0">Details</h5>
  </div>
  <div class="card-body">
    <div class="row">
      <div class="col-md-6 mb-3"><div class="text-muted small">Referral</div><div class="fw-medium"><%= display_attr(@thank_you_slip, :referral_id) %></div></div>
      <div class="col-md-6 mb-3"><div class="text-muted small">Business Value</div><div class="fw-medium"><%= display_attr(@thank_you_slip, :business_value) %></div></div>
      <div class="col-md-6 mb-3"><div class="text-muted small">Invoice Number</div><div class="fw-medium"><%= display_attr(@thank_you_slip, :invoice_number) %></div></div>
      <div class="col-md-6 mb-3"><div class="text-muted small">Client Name</div><div class="fw-medium"><%= display_attr(@thank_you_slip, :client_name) %></div></div>
      <div class="col-md-6 mb-3"><div class="text-muted small">Received By</div><div class="fw-medium"><%= display_attr(@thank_you_slip, :received_by_member_id) %></div></div>
      <div class="col-md-6 mb-3"><div class="text-muted small">Thanked To</div><div class="fw-medium"><%= display_attr(@thank_you_slip, :thanked_to_member_id) %></div></div>
      <div class="col-md-6 mb-3"><div class="text-muted small">Date</div><div class="fw-medium"><%= display_attr(@thank_you_slip, :date) %></div></div>
      <div class="col-md-6 mb-3"><div class="text-muted small">Notes</div><div class="fw-medium"><%= display_attr(@thank_you_slip, :notes) %></div></div>
    </div>
  </div>
</div>
