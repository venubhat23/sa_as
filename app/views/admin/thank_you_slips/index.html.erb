<% page_title "Thank You Slips" %>

<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="mb-1">Thank You Slip Management</h2>
    <p class="text-muted mb-0">Manage your thank you slips here</p>
  </div>
  <div>
    <%= link_to new_admin_thank_you_slip_path, class: "btn btn-primary" do %>
      <i class="bi bi-plus-lg me-1"></i> Add New Thank You Slip
    <% end %>
  </div>
</div>

<!-- Table Card -->
<div class="card border-0 shadow-sm">
  <div class="card-header bg-transparent border-0">
    <h5 class="mb-0">Thank You Slip List</h5>
  </div>
  <div class="card-body p-0">
    <% if @thank_you_slips.any? %>
      <div class="table-responsive">
        <table class="table table-hover mb-0">
          <thead class="table-light">
            <tr>
              <th class="border-0 fw-semibold">Date</th>
              <th class="border-0 fw-semibold">Client</th>
              <th class="border-0 fw-semibold">Business Value</th>
              <th class="border-0 fw-semibold">Invoice #</th>
              <th class="border-0 fw-semibold">Received By</th>
              <th class="border-0 fw-semibold">Thanked To</th>
              <th class="border-0 fw-semibold">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% @thank_you_slips.each do |f| %>
              <tr>
                <td class="align-middle"><%= f.date %></td>
                <td class="align-middle"><%= f.client_name %></td>
                <td class="align-middle"><%= inr(f.business_value) %></td>
                <td class="align-middle"><%= f.invoice_number %></td>
                <td class="align-middle"><%= f.received_by_member&.full_name %></td>
                <td class="align-middle"><%= f.thanked_to_member&.full_name %></td>
                <td class="align-middle">
                  <div class="dropdown">
                    <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown">
                      <i class="bi bi-three-dots"></i>
                    </button>
                    <ul class="dropdown-menu">
                      <li><%= link_to admin_thank_you_slip_path(f), class: "dropdown-item" do %><i class="bi bi-eye me-2"></i>View<% end %></li>
                      <li><%= link_to edit_admin_thank_you_slip_path(f), class: "dropdown-item" do %><i class="bi bi-pencil me-2"></i>Edit<% end %></li>
                      <li><hr class="dropdown-divider"></li>
                      <li><%= link_to admin_thank_you_slip_path(f), data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "dropdown-item text-danger" do %><i class="bi bi-trash me-2"></i>Delete<% end %></li>
                    </ul>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      <div class="card-footer bg-transparent border-0">
        <%= paginate @thank_you_slips if @thank_you_slips.respond_to?(:current_page) %>
      </div>
    <% else %>
      <div class="text-center py-5">
        <i class="bi bi-receipt-cutoff fs-1 text-muted mb-3 d-block"></i>
        <h5 class="text-muted mb-3">No Thank You Slips Found</h5>
        <p class="text-muted mb-4">Get started by adding your first thank you slip.</p>
        <%= link_to "Add Thank You Slip", new_admin_thank_you_slip_path, class: "btn btn-primary" %>
      </div>
    <% end %>
  </div>
</div>
