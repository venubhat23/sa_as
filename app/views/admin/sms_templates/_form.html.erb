<%= form_with model: [:admin, @sms_template], local: true do |form| %>
  <% if @sms_template.errors.any? %>
    <div class="alert alert-danger">
      <strong><%= pluralize(@sms_template.errors.count, "error") %> prevented saving:</strong>
      <ul class="mb-0"><% @sms_template.errors.full_messages.each do |m| %><li><%= m %></li><% end %></ul>
    </div>
  <% end %>
  <div class="row">
    <div class="col-md-6 mb-3">
      <%= form.label :name, "Name", class: "form-label" %>
      <%= form.text_field :name, class: "form-control" %>
    </div>
    <div class="col-md-12 mb-3">
      <%= form.label :body, "Body", class: "form-label" %>
      <%= form.text_area :body, class: "form-control", rows: 3 %>
    </div>
    <div class="col-md-6 mb-3">
      <%= form.label :template_type, "Template Type", class: "form-label" %>
      <%= form.text_field :template_type, class: "form-control" %>
    </div>
    <div class="col-md-6 mb-3">
      <%= form.label :status, "Status", class: "form-label" %>
      <%= form.select :status, ["active", "inactive"], { include_blank: "Select" }, class: "form-select" %>
    </div>
  </div>
  <div class="mt-3">
    <%= form.submit "Save", class: "btn btn-primary" %>
    <%= link_to "Cancel", admin_sms_templates_path, class: "btn btn-light" %>
  </div>
<% end %>
