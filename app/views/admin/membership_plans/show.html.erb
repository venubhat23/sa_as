<% page_title "Membership Plan Details" %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="mb-1"><%= @membership_plan.name %></h2>
    <p class="text-muted mb-0">Membership Plan Details</p>
  </div>
  <div class="d-flex gap-2">
    <%= link_to edit_admin_membership_plan_path(@membership_plan), class: "btn btn-primary" do %>
      <i class="bi bi-pencil me-1"></i>Edit
    <% end %>
    <%= link_to admin_membership_plans_path, class: "btn btn-outline-secondary" do %>
      <i class="bi bi-arrow-left me-1"></i>Back
    <% end %>
  </div>
</div>

<div class="card border-0 shadow-sm">
  <div class="card-header bg-transparent border-0">
    <h5 class="mb-0">Details</h5>
  </div>
  <div class="card-body">
    <div class="row">
      <div class="col-md-6 mb-3"><div class="text-muted small">Name</div><div class="fw-medium"><%= display_attr(@membership_plan, :name) %></div></div>
      <div class="col-md-6 mb-3"><div class="text-muted small">Duration (months)</div><div class="fw-medium"><%= display_attr(@membership_plan, :duration_months) %></div></div>
      <div class="col-md-6 mb-3"><div class="text-muted small">Fee Amount</div><div class="fw-medium"><%= display_attr(@membership_plan, :fee_amount) %></div></div>
      <div class="col-md-6 mb-3"><div class="text-muted small">Description</div><div class="fw-medium"><%= display_attr(@membership_plan, :description) %></div></div>
      <div class="col-md-6 mb-3"><div class="text-muted small">Status</div><div class="fw-medium"><%= display_attr(@membership_plan, :status) %></div></div>
    </div>
  </div>
</div>
