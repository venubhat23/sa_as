<% page_title "Calendar" %>

<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="mb-1">Calendar - <%= @date.strftime("%B %Y") %></h2>
    <p class="text-muted mb-0">View meetings, events, and renewals</p>
  </div>
  <div class="d-flex gap-2">
    <%= link_to admin_calendar_path(date: (@date << 1).to_s), class: "btn btn-outline-secondary" do %>
      <i class="bi bi-chevron-left"></i>
    <% end %>
    <%= link_to "Today", admin_calendar_path, class: "btn btn-outline-secondary" %>
    <%= link_to admin_calendar_path(date: (@date >> 1).to_s), class: "btn btn-outline-secondary" do %>
      <i class="bi bi-chevron-right"></i>
    <% end %>
  </div>
</div>

<div class="card border-0 shadow-sm">
  <div class="card-body p-0">
    <table class="table table-bordered text-center mb-0" style="table-layout:fixed;">
      <thead class="table-light">
        <tr>
          <% %w[Sun Mon Tue Wed Thu Fri Sat].each do |d| %>
            <th class="border-0 fw-semibold"><%= d %></th>
          <% end %>
        </tr>
      </thead>
      <tbody>
        <% (@start_date..@end_date).each_slice(7) do |week| %>
          <tr style="height:110px;">
            <% week.each do |day| %>
              <td class="align-top text-start p-2 <%= 'bg-light text-muted' if day.month != @date.month %>" style="vertical-align:top;">
                <div class="fw-bold <%= 'text-primary' if day == Date.current %>"><%= day.day %></div>
                <% @meetings.select { |m| m.meeting_date == day }.each do |m| %>
                  <div class="badge bg-primary text-truncate w-100 mt-1" title="Meeting"><i class="bi bi-calendar-check"></i> Meeting</div>
                <% end %>
                <% @events.select { |e| e.start_date&.to_date == day }.each do |e| %>
                  <div class="badge bg-info text-truncate w-100 mt-1" title="<%= e.title %>"><i class="bi bi-star"></i> <%= e.title %></div>
                <% end %>
                <% @renewals.select { |r| r.renewal_date == day }.each do |r| %>
                  <div class="badge bg-warning text-truncate w-100 mt-1" title="Renewal"><i class="bi bi-arrow-repeat"></i> Renewal</div>
                <% end %>
              </td>
            <% end %>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
