<% page_title "Notification Details" %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="mb-1"><%= @notification.title %></h2>
    <p class="text-muted mb-0">Notification Details</p>
  </div>
  <div class="d-flex gap-2">
    <%= link_to edit_admin_notification_path(@notification), class: "btn btn-primary" do %>
      <i class="bi bi-pencil me-1"></i>Edit
    <% end %>
    <%= link_to admin_notifications_path, class: "btn btn-outline-secondary" do %>
      <i class="bi bi-arrow-left me-1"></i>Back
    <% end %>
  </div>
</div>

<div class="card border-0 shadow-sm">
  <div class="card-header bg-transparent border-0">
    <h5 class="mb-0">Details</h5>
  </div>
  <div class="card-body">
    <div class="row">
      <div class="col-md-6 mb-3"><div class="text-muted small">User</div><div class="fw-medium"><%= display_attr(@notification, :user_id) %></div></div>
      <div class="col-md-6 mb-3"><div class="text-muted small">Title</div><div class="fw-medium"><%= display_attr(@notification, :title) %></div></div>
      <div class="col-md-6 mb-3"><div class="text-muted small">Body</div><div class="fw-medium"><%= display_attr(@notification, :body) %></div></div>
      <div class="col-md-6 mb-3"><div class="text-muted small">Notification Type</div><div class="fw-medium"><%= display_attr(@notification, :notification_type) %></div></div>
      <div class="col-md-6 mb-3"><div class="text-muted small">Sent At</div><div class="fw-medium"><%= display_attr(@notification, :sent_at) %></div></div>
    </div>
  </div>
</div>
