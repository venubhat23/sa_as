<% page_title "User Account Details" %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="mb-1"><%= @user.name %></h2>
    <p class="text-muted mb-0">User Account Details</p>
  </div>
  <div class="d-flex gap-2">
    <%= link_to edit_admin_user_path(@user), class: "btn btn-primary" do %>
      <i class="bi bi-pencil me-1"></i>Edit
    <% end %>
    <%= link_to admin_users_path, class: "btn btn-outline-secondary" do %>
      <i class="bi bi-arrow-left me-1"></i>Back
    <% end %>
  </div>
</div>

<div class="card border-0 shadow-sm">
  <div class="card-header bg-transparent border-0">
    <h5 class="mb-0">Details</h5>
  </div>
  <div class="card-body">
    <div class="row">
      <div class="col-md-6 mb-3"><div class="text-muted small">Email</div><div class="fw-medium"><%= display_attr(@user, :email) %></div></div>
      <div class="col-md-6 mb-3"><div class="text-muted small">Name</div><div class="fw-medium"><%= display_attr(@user, :name) %></div></div>
      <div class="col-md-6 mb-3"><div class="text-muted small">Phone</div><div class="fw-medium"><%= display_attr(@user, :phone) %></div></div>
      <div class="col-md-6 mb-3"><div class="text-muted small">Role</div><div class="fw-medium"><%= display_attr(@user, :role_id) %></div></div>
      <div class="col-md-6 mb-3"><div class="text-muted small">Status</div><div class="fw-medium"><%= display_attr(@user, :status) %></div></div>
    </div>
  </div>
</div>
