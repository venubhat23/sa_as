<%= form_with model: [:admin, @user], local: true do |form| %>
  <% if @user.errors.any? %>
    <div class="alert alert-danger">
      <strong><%= pluralize(@user.errors.count, "error") %> prevented saving:</strong>
      <ul class="mb-0"><% @user.errors.full_messages.each do |m| %><li><%= m %></li><% end %></ul>
    </div>
  <% end %>
  <div class="row">
    <div class="col-md-6 mb-3">
      <%= form.label :email, "Email", class: "form-label" %>
      <%= form.text_field :email, class: "form-control" %>
    </div>
    <div class="col-md-6 mb-3">
      <%= form.label :name, "Name", class: "form-label" %>
      <%= form.text_field :name, class: "form-control" %>
    </div>
    <div class="col-md-6 mb-3">
      <%= form.label :phone, "Phone", class: "form-label" %>
      <%= form.text_field :phone, class: "form-control" %>
    </div>
    <div class="col-md-6 mb-3">
      <%= form.label :role_id, "Role", class: "form-label" %>
      <%= form.collection_select :role_id, Role.all, :id, :name, { include_blank: "Select Role" }, class: "form-select select2" %>
    </div>
    <div class="col-md-6 mb-3">
      <%= form.label :status, "Status", class: "form-label" %>
      <%= form.select :status, ["active", "inactive"], { include_blank: "Select" }, class: "form-select" %>
    </div>
  </div>
  <div class="mt-3">
    <%= form.submit "Save", class: "btn btn-primary" %>
    <%= link_to "Cancel", admin_users_path, class: "btn btn-light" %>
  </div>
<% end %>
