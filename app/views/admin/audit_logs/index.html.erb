<% page_title "Audit Logs" %>

<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="mb-1">Audit Logs</h2>
    <p class="text-muted mb-0">View system audit trail</p>
  </div>
</div>

<!-- Table Card -->
<div class="card border-0 shadow-sm">
  <div class="card-header bg-transparent border-0">
    <h5 class="mb-0">Log Entries</h5>
  </div>
  <div class="card-body p-0">
    <% if @audit_logs.any? %>
      <div class="table-responsive">
        <table class="table table-hover mb-0">
          <thead class="table-light">
            <tr>
              <th class="border-0 fw-semibold">Time</th>
              <th class="border-0 fw-semibold">User</th>
              <th class="border-0 fw-semibold">Action</th>
              <th class="border-0 fw-semibold">Resource</th>
              <th class="border-0 fw-semibold">IP</th>
            </tr>
          </thead>
          <tbody>
            <% @audit_logs.each do |log| %>
              <tr>
                <td class="align-middle"><%= log.created_at.strftime("%d %b %Y %H:%M") %></td>
                <td class="align-middle"><%= log.user&.display_name %></td>
                <td class="align-middle"><%= log.action %></td>
                <td class="align-middle"><%= log.resource_type %> #<%= log.resource_id %></td>
                <td class="align-middle"><%= log.ip_address %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      <div class="card-footer bg-transparent border-0">
        <%= paginate @audit_logs %>
      </div>
    <% else %>
      <div class="text-center py-5">
        <i class="bi bi-clock-history fs-1 text-muted mb-3 d-block"></i>
        <h5 class="text-muted mb-3">No Audit Logs Found</h5>
        <p class="text-muted mb-4">System activity will appear here.</p>
      </div>
    <% end %>
  </div>
</div>
