<%= form_with model: [:admin, @region], local: true do |form| %>
  <% if @region.errors.any? %>
    <div class="alert alert-danger">
      <strong><%= pluralize(@region.errors.count, "error") %> prevented saving:</strong>
      <ul class="mb-0"><% @region.errors.full_messages.each do |m| %><li><%= m %></li><% end %></ul>
    </div>
  <% end %>
  <div class="row">
    <div class="col-md-6 mb-3">
      <%= form.label :name, "Name", class: "form-label" %>
      <%= form.text_field :name, class: "form-control" %>
    </div>
    <div class="col-md-6 mb-3">
      <%= form.label :code, "Code", class: "form-label" %>
      <%= form.text_field :code, class: "form-control" %>
    </div>
    <div class="col-md-12 mb-3">
      <%= form.label :description, "Description", class: "form-label" %>
      <%= form.text_area :description, class: "form-control", rows: 3 %>
    </div>
    <div class="col-md-6 mb-3">
      <%= form.label :status, "Status", class: "form-label" %>
      <%= form.select :status, ["active", "inactive"], { include_blank: "Select" }, class: "form-select" %>
    </div>
  </div>
  <div class="mt-3">
    <%= form.submit "Save", class: "btn btn-primary" %>
    <%= link_to "Cancel", admin_regions_path, class: "btn btn-light" %>
  </div>
<% end %>
