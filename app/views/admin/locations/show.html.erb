<% page_title "Location Details" %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="mb-1"><%= @location.name %></h2>
    <p class="text-muted mb-0">Location Details</p>
  </div>
  <div class="d-flex gap-2">
    <%= link_to edit_admin_location_path(@location), class: "btn btn-primary" do %>
      <i class="bi bi-pencil me-1"></i>Edit
    <% end %>
    <%= link_to admin_locations_path, class: "btn btn-outline-secondary" do %>
      <i class="bi bi-arrow-left me-1"></i>Back
    <% end %>
  </div>
</div>

<div class="card border-0 shadow-sm">
  <div class="card-header bg-transparent border-0">
    <h5 class="mb-0">Details</h5>
  </div>
  <div class="card-body">
    <div class="row">
      <div class="col-md-6 mb-3"><div class="text-muted small">Name</div><div class="fw-medium"><%= display_attr(@location, :name) %></div></div>
      <div class="col-md-6 mb-3"><div class="text-muted small">Address</div><div class="fw-medium"><%= display_attr(@location, :address) %></div></div>
      <div class="col-md-6 mb-3"><div class="text-muted small">City</div><div class="fw-medium"><%= display_attr(@location, :city) %></div></div>
      <div class="col-md-6 mb-3"><div class="text-muted small">State</div><div class="fw-medium"><%= display_attr(@location, :state) %></div></div>
      <div class="col-md-6 mb-3"><div class="text-muted small">Pincode</div><div class="fw-medium"><%= display_attr(@location, :pincode) %></div></div>
      <div class="col-md-6 mb-3"><div class="text-muted small">Region</div><div class="fw-medium"><%= display_attr(@location, :region_id) %></div></div>
      <div class="col-md-6 mb-3"><div class="text-muted small">Chapter</div><div class="fw-medium"><%= display_attr(@location, :chapter_id) %></div></div>
    </div>
  </div>
</div>
