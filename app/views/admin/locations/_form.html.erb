<%= form_with model: [:admin, @location], local: true do |form| %>
  <% if @location.errors.any? %>
    <div class="alert alert-danger">
      <strong><%= pluralize(@location.errors.count, "error") %> prevented saving:</strong>
      <ul class="mb-0"><% @location.errors.full_messages.each do |m| %><li><%= m %></li><% end %></ul>
    </div>
  <% end %>
  <div class="row">
    <div class="col-md-6 mb-3">
      <%= form.label :name, "Name", class: "form-label" %>
      <%= form.text_field :name, class: "form-control" %>
    </div>
    <div class="col-md-12 mb-3">
      <%= form.label :address, "Address", class: "form-label" %>
      <%= form.text_area :address, class: "form-control", rows: 3 %>
    </div>
    <div class="col-md-6 mb-3">
      <%= form.label :city, "City", class: "form-label" %>
      <%= form.text_field :city, class: "form-control" %>
    </div>
    <div class="col-md-6 mb-3">
      <%= form.label :state, "State", class: "form-label" %>
      <%= form.text_field :state, class: "form-control" %>
    </div>
    <div class="col-md-6 mb-3">
      <%= form.label :pincode, "Pincode", class: "form-label" %>
      <%= form.text_field :pincode, class: "form-control" %>
    </div>
    <div class="col-md-6 mb-3">
      <%= form.label :region_id, "Region", class: "form-label" %>
      <%= form.collection_select :region_id, Region.all, :id, :name, { include_blank: "Select Region" }, class: "form-select select2" %>
    </div>
    <div class="col-md-6 mb-3">
      <%= form.label :chapter_id, "Chapter", class: "form-label" %>
      <%= form.collection_select :chapter_id, Chapter.all, :id, :name, { include_blank: "Select Chapter" }, class: "form-select select2" %>
    </div>
  </div>
  <div class="mt-3">
    <%= form.submit "Save", class: "btn btn-primary" %>
    <%= link_to "Cancel", admin_locations_path, class: "btn btn-light" %>
  </div>
<% end %>
