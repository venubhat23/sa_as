<% page_title "Guests" %>

<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="mb-1">Guest Management</h2>
    <p class="text-muted mb-0">Manage your guests here</p>
  </div>
  <div>
    <%= link_to new_admin_guest_path, class: "btn btn-primary" do %>
      <i class="bi bi-plus-lg me-1"></i> Add New Guest
    <% end %>
  </div>
</div>

<!-- Stats Cards -->
<div class="row mb-4">
  <div class="col-md-3">
    <div class="card border-0 shadow-sm">
      <div class="card-body">
        <div class="d-flex align-items-center">
          <div class="flex-grow-1">
            <h6 class="text-muted mb-1">Total Guests</h6>
            <h4 class="mb-0"><%= @total_count %></h4>
          </div>
          <div class="text-primary"><i class="bi bi-person-plus-fill fs-2"></i></div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card border-0 shadow-sm">
      <div class="card-body">
        <div class="d-flex align-items-center">
          <div class="flex-grow-1">
            <h6 class="text-muted mb-1">Converted</h6>
            <h4 class="mb-0"><%= @converted_count %></h4>
          </div>
          <div class="text-success"><i class="bi bi-arrow-right-circle-fill fs-2"></i></div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Filter Card -->
<div class="card border-0 shadow-sm mb-4">
  <div class="card-body">
    <%= form_with url: admin_guests_path, method: :get, local: true do |f| %>
      <div class="row g-2 align-items-end">
        <div class="col-md-4">
          <%= f.label :lifecycle_status, "Lifecycle Stage", class: "form-label" %>
          <%= f.select :lifecycle_status, Guest.lifecycle_statuses.keys, { include_blank: "All Stages", selected: params[:lifecycle_status] }, class: "form-select" %>
        </div>
        <div class="col-md-4">
          <%= f.submit "Filter", class: "btn btn-primary" %>
          <%= link_to "Reset", admin_guests_path, class: "btn btn-outline-secondary ms-1" %>
        </div>
      </div>
    <% end %>
  </div>
</div>

<!-- Table Card -->
<div class="card border-0 shadow-sm">
  <div class="card-header bg-transparent border-0">
    <h5 class="mb-0">Guest List</h5>
  </div>
  <div class="card-body p-0">
    <% if @guests.any? %>
      <div class="table-responsive">
        <table class="table table-hover mb-0">
          <thead class="table-light">
            <tr>
              <th class="border-0 fw-semibold">Name</th>
              <th class="border-0 fw-semibold">Company</th>
              <th class="border-0 fw-semibold">Phone</th>
              <th class="border-0 fw-semibold">Invited By</th>
              <th class="border-0 fw-semibold">Stage</th>
              <th class="border-0 fw-semibold">Visit Date</th>
              <th class="border-0 fw-semibold">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% @guests.each do |g| %>
              <tr>
                <td class="align-middle"><%= link_to g.name, admin_guest_path(g), class: "fw-medium text-decoration-none" %></td>
                <td class="align-middle"><%= g.company_name %></td>
                <td class="align-middle"><%= g.phone %></td>
                <td class="align-middle"><%= g.invited_by_member&.full_name %></td>
                <td class="align-middle"><%= status_badge(g.lifecycle_status) %></td>
                <td class="align-middle"><%= g.visit_date %></td>
                <td class="align-middle">
                  <div class="dropdown">
                    <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown">
                      <i class="bi bi-three-dots"></i>
                    </button>
                    <ul class="dropdown-menu">
                      <li><%= link_to admin_guest_path(g), class: "dropdown-item" do %><i class="bi bi-eye me-2"></i>View<% end %></li>
                      <li><%= link_to edit_admin_guest_path(g), class: "dropdown-item" do %><i class="bi bi-pencil me-2"></i>Edit<% end %></li>
                      <% unless g.lifecycle_status_converted? %>
                        <li><%= link_to convert_to_member_admin_guest_path(g), data: { turbo_method: :patch, turbo_confirm: "Convert this guest to member?" }, class: "dropdown-item text-success" do %><i class="bi bi-arrow-right-circle me-2"></i>Convert to Member<% end %></li>
                      <% end %>
                      <li><hr class="dropdown-divider"></li>
                      <li><%= link_to admin_guest_path(g), data: { turbo_method: :delete, turbo_confirm: "Delete?" }, class: "dropdown-item text-danger" do %><i class="bi bi-trash me-2"></i>Delete<% end %></li>
                    </ul>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      <div class="card-footer bg-transparent border-0">
        <%= paginate @guests %>
      </div>
    <% else %>
      <div class="text-center py-5">
        <i class="bi bi-person-plus-fill fs-1 text-muted mb-3 d-block"></i>
        <h5 class="text-muted mb-3">No Guests Found</h5>
        <p class="text-muted mb-4">Get started by adding your first guest.</p>
        <%= link_to "Add Guest", new_admin_guest_path, class: "btn btn-primary" %>
      </div>
    <% end %>
  </div>
</div>
