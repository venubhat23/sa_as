<% page_title @guest.name %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="mb-1"><%= @guest.name %> <%= status_badge(@guest.lifecycle_status) %></h2>
    <p class="text-muted mb-0">Guest Details</p>
  </div>
  <div class="d-flex gap-2">
    <% unless @guest.lifecycle_status_converted? %>
      <%= link_to convert_to_member_admin_guest_path(@guest), data: { turbo_method: :patch, turbo_confirm: "Convert to member?" }, class: "btn btn-success" do %>
        <i class="bi bi-arrow-right-circle me-1"></i>Convert to Member
      <% end %>
    <% end %>
    <%= link_to edit_admin_guest_path(@guest), class: "btn btn-primary" do %>
      <i class="bi bi-pencil me-1"></i>Edit
    <% end %>
    <%= link_to admin_guests_path, class: "btn btn-outline-secondary" do %>
      <i class="bi bi-arrow-left me-1"></i>Back
    <% end %>
  </div>
</div>

<div class="card border-0 shadow-sm">
  <div class="card-header bg-transparent border-0">
    <h5 class="mb-0">Details</h5>
  </div>
  <div class="card-body">
    <div class="row">
      <div class="col-md-6 mb-3"><div class="text-muted small">Phone</div><div class="fw-medium"><%= display_attr(@guest, :phone) %></div></div>
      <div class="col-md-6 mb-3"><div class="text-muted small">Email</div><div class="fw-medium"><%= display_attr(@guest, :email) %></div></div>
      <div class="col-md-6 mb-3"><div class="text-muted small">Company</div><div class="fw-medium"><%= display_attr(@guest, :company_name) %></div></div>
      <div class="col-md-6 mb-3"><div class="text-muted small">Category</div><div class="fw-medium"><%= @guest.business_category&.name || "—" %></div></div>
      <div class="col-md-6 mb-3"><div class="text-muted small">Invited By</div><div class="fw-medium"><%= @guest.invited_by_member&.full_name || "—" %></div></div>
      <div class="col-md-6 mb-3"><div class="text-muted small">Chapter</div><div class="fw-medium"><%= @guest.chapter&.name || "—" %></div></div>
      <div class="col-md-6 mb-3"><div class="text-muted small">Visit Date</div><div class="fw-medium"><%= display_attr(@guest, :visit_date) %></div></div>
      <div class="col-md-12 mb-3"><div class="text-muted small">Notes</div><div class="fw-medium"><%= display_attr(@guest, :notes) %></div></div>
    </div>
  </div>
</div>
