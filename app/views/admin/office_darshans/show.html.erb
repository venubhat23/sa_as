<% page_title "Office Darshan Details" %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="mb-1">Office Darshan Details</h2>
    <p class="text-muted mb-0">Visit Information</p>
  </div>
  <div class="d-flex gap-2">
    <%= link_to edit_admin_office_darshan_path(@office_darshan), class: "btn btn-primary" do %>
      <i class="bi bi-pencil me-1"></i>Edit
    <% end %>
    <%= link_to admin_office_darshans_path, class: "btn btn-outline-secondary" do %>
      <i class="bi bi-arrow-left me-1"></i>Back
    <% end %>
  </div>
</div>

<div class="card border-0 shadow-sm">
  <div class="card-header bg-transparent border-0">
    <h5 class="mb-0">Details</h5>
  </div>
  <div class="card-body">
    <div class="row">
      <div class="col-md-6 mb-3"><div class="text-muted small">Host Member</div><div class="fw-medium"><%= display_attr(@office_darshan, :host_member_id) %></div></div>
      <div class="col-md-6 mb-3"><div class="text-muted small">Visit Date</div><div class="fw-medium"><%= display_attr(@office_darshan, :visit_date) %></div></div>
      <div class="col-md-6 mb-3"><div class="text-muted small">Purpose</div><div class="fw-medium"><%= display_attr(@office_darshan, :purpose) %></div></div>
      <div class="col-md-6 mb-3"><div class="text-muted small">Feedback</div><div class="fw-medium"><%= display_attr(@office_darshan, :feedback) %></div></div>
      <div class="col-md-6 mb-3"><div class="text-muted small">Status</div><div class="fw-medium"><%= display_attr(@office_darshan, :status) %></div></div>
    </div>
  </div>
</div>
