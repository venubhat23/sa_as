<% page_title "Reports & Analytics" %>

<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="mb-1">Reports & Analytics</h2>
    <p class="text-muted mb-0">View insights and data analytics</p>
  </div>
</div>

<!-- Report Navigation -->
<div class="card border-0 shadow-sm mb-4">
  <div class="card-body">
    <div class="d-flex flex-wrap gap-2">
      <%= link_to "Members", admin_reports_members_path, class: "btn btn-outline-primary" %>
      <%= link_to "Attendance", admin_reports_attendance_path, class: "btn btn-outline-primary" %>
      <%= link_to "Referrals", admin_reports_referrals_path, class: "btn btn-outline-primary" %>
      <%= link_to "Revenue", admin_reports_revenue_path, class: "btn btn-outline-primary" %>
      <%= link_to "Guest Conversion", admin_reports_guest_conversion_path, class: "btn btn-outline-primary" %>
    </div>
  </div>
</div>

<!-- Charts -->
<div class="row g-3">
  <div class="col-lg-6">
    <div class="card border-0 shadow-sm">
      <div class="card-header bg-transparent border-0">
        <h5 class="mb-0">Members by Status</h5>
      </div>
      <div class="card-body">
        <%= pie_chart @members_by_status, height: "260px" %>
      </div>
    </div>
  </div>
  <div class="col-lg-6">
    <div class="card border-0 shadow-sm">
      <div class="card-header bg-transparent border-0">
        <h5 class="mb-0">Members by Chapter</h5>
      </div>
      <div class="card-body">
        <%= column_chart @members_by_chapter, height: "260px" %>
      </div>
    </div>
  </div>
  <div class="col-lg-6">
    <div class="card border-0 shadow-sm">
      <div class="card-header bg-transparent border-0">
        <h5 class="mb-0">Referral Trend</h5>
      </div>
      <div class="card-body">
        <%= line_chart @referral_trend, height: "260px" %>
      </div>
    </div>
  </div>
  <div class="col-lg-6">
    <div class="card border-0 shadow-sm">
      <div class="card-header bg-transparent border-0">
        <h5 class="mb-0">Revenue Trend</h5>
      </div>
      <div class="card-body">
        <%= column_chart @revenue_trend, height: "260px" %>
      </div>
    </div>
  </div>
  <div class="col-lg-6">
    <div class="card border-0 shadow-sm">
      <div class="card-header bg-transparent border-0">
        <h5 class="mb-0">Guest Conversion</h5>
      </div>
      <div class="card-body">
        <%= pie_chart @guest_conversion, height: "260px" %>
      </div>
    </div>
  </div>
</div>
