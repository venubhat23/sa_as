<% page_title "Revenue Report" %>
<div class="page-header"><h1><i class="bi bi-cash-stack me-2"></i>Revenue Report</h1><%= link_to "Back", admin_reports_path, class: "btn btn-light" %></div>
<div class="stat-card bg-gradient-green mb-3" style="max-width:300px;"><div class="stat-value"><%= inr(@total) %></div><div class="stat-label">Total Revenue</div></div>
<div class="row g-3">
  <div class="col-lg-8"><div class="card"><div class="card-header">Revenue Trend</div><div class="card-body"><%= column_chart @revenue_trend, height: "280px" %></div></div></div>
  <div class="col-lg-4"><div class="card"><div class="card-header">By Payment Mode</div><div class="card-body"><%= pie_chart @by_mode, height: "280px" %></div></div></div>
</div>
