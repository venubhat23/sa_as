<%= form_with model: [:admin, @fee_collection], local: true do |form| %>
  <% if @fee_collection.errors.any? %>
    <div class="alert alert-danger">
      <strong><%= pluralize(@fee_collection.errors.count, "error") %> prevented saving:</strong>
      <ul class="mb-0"><% @fee_collection.errors.full_messages.each do |m| %><li><%= m %></li><% end %></ul>
    </div>
  <% end %>
  <div class="row">
    <div class="col-md-6 mb-3">
      <%= form.label :member_id, "Member", class: "form-label" %>
      <%= form.collection_select :member_id, Member.all, :id, :full_name, { include_blank: "Select Member" }, class: "form-select select2" %>
    </div>
    <div class="col-md-6 mb-3">
      <%= form.label :amount, "Amount", class: "form-label" %>
      <%= form.number_field :amount, step: :any, class: "form-control" %>
    </div>
    <div class="col-md-6 mb-3">
      <%= form.label :payment_mode, "Payment Mode", class: "form-label" %>
      <%= form.select :payment_mode, ["Cash", "Card", "UPI", "Cheque", "BankTransfer"], { include_blank: "Select" }, class: "form-select" %>
    </div>
    <div class="col-md-6 mb-3">
      <%= form.label :payment_date, "Payment Date", class: "form-label" %>
      <%= form.date_field :payment_date, class: "form-control" %>
    </div>
    <div class="col-md-6 mb-3">
      <%= form.label :receipt_number, "Receipt Number", class: "form-label" %>
      <%= form.text_field :receipt_number, class: "form-control" %>
    </div>
    <div class="col-md-6 mb-3">
      <%= form.label :status, "Status", class: "form-label" %>
      <%= form.select :status, ["completed", "pending"], { include_blank: "Select" }, class: "form-select" %>
    </div>
    <div class="col-md-12 mb-3">
      <%= form.label :notes, "Notes", class: "form-label" %>
      <%= form.text_area :notes, class: "form-control", rows: 3 %>
    </div>
  </div>
  <div class="mt-3">
    <%= form.submit "Save", class: "btn btn-primary" %>
    <%= link_to "Cancel", admin_fee_collections_path, class: "btn btn-light" %>
  </div>
<% end %>
