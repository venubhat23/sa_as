<% page_title "Fee Collection Details" %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="mb-1">Fee Collection Details</h2>
    <p class="text-muted mb-0">Fee Collection Information</p>
  </div>
  <div class="d-flex gap-2">
    <%= link_to edit_admin_fee_collection_path(@fee_collection), class: "btn btn-primary" do %>
      <i class="bi bi-pencil me-1"></i>Edit
    <% end %>
    <%= link_to admin_fee_collections_path, class: "btn btn-outline-secondary" do %>
      <i class="bi bi-arrow-left me-1"></i>Back
    <% end %>
  </div>
</div>

<div class="card border-0 shadow-sm">
  <div class="card-header bg-transparent border-0">
    <h5 class="mb-0">Details</h5>
  </div>
  <div class="card-body">
    <div class="row">
      <div class="col-md-6 mb-3"><div class="text-muted small">Member</div><div class="fw-medium"><%= display_attr(@fee_collection, :member_id) %></div></div>
      <div class="col-md-6 mb-3"><div class="text-muted small">Amount</div><div class="fw-medium"><%= display_attr(@fee_collection, :amount) %></div></div>
      <div class="col-md-6 mb-3"><div class="text-muted small">Payment Mode</div><div class="fw-medium"><%= display_attr(@fee_collection, :payment_mode) %></div></div>
      <div class="col-md-6 mb-3"><div class="text-muted small">Payment Date</div><div class="fw-medium"><%= display_attr(@fee_collection, :payment_date) %></div></div>
      <div class="col-md-6 mb-3"><div class="text-muted small">Receipt Number</div><div class="fw-medium"><%= display_attr(@fee_collection, :receipt_number) %></div></div>
      <div class="col-md-6 mb-3"><div class="text-muted small">Status</div><div class="fw-medium"><%= display_attr(@fee_collection, :status) %></div></div>
      <div class="col-md-6 mb-3"><div class="text-muted small">Notes</div><div class="fw-medium"><%= display_attr(@fee_collection, :notes) %></div></div>
    </div>
  </div>
</div>
