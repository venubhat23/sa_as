<%= form_with model: [:admin, @event], local: true do |form| %>
  <% if @event.errors.any? %>
    <div class="alert alert-danger">
      <strong><%= pluralize(@event.errors.count, "error") %> prevented saving:</strong>
      <ul class="mb-0"><% @event.errors.full_messages.each do |m| %><li><%= m %></li><% end %></ul>
    </div>
  <% end %>
  <div class="row">
    <div class="col-md-6 mb-3">
      <%= form.label :title, "Title", class: "form-label" %>
      <%= form.text_field :title, class: "form-control" %>
    </div>
    <div class="col-md-6 mb-3">
      <%= form.label :event_type, "Event Type", class: "form-label" %>
      <%= form.text_field :event_type, class: "form-control" %>
    </div>
    <div class="col-md-6 mb-3">
      <%= form.label :start_date, "Start Date", class: "form-label" %>
      <%= form.datetime_local_field :start_date, class: "form-control" %>
    </div>
    <div class="col-md-6 mb-3">
      <%= form.label :end_date, "End Date", class: "form-label" %>
      <%= form.datetime_local_field :end_date, class: "form-control" %>
    </div>
    <div class="col-md-6 mb-3">
      <%= form.label :venue, "Venue", class: "form-label" %>
      <%= form.text_field :venue, class: "form-control" %>
    </div>
    <div class="col-md-12 mb-3">
      <%= form.label :description, "Description", class: "form-label" %>
      <%= form.text_area :description, class: "form-control", rows: 3 %>
    </div>
    <div class="col-md-6 mb-3">
      <%= form.label :capacity, "Capacity", class: "form-label" %>
      <%= form.number_field :capacity, step: :any, class: "form-control" %>
    </div>
    <div class="col-md-6 mb-3">
      <%= form.label :registration_fee, "Registration Fee", class: "form-label" %>
      <%= form.number_field :registration_fee, step: :any, class: "form-control" %>
    </div>
    <div class="col-md-6 mb-3">
      <%= form.label :status, "Status", class: "form-label" %>
      <%= form.select :status, ["upcoming", "ongoing", "completed", "cancelled"], { include_blank: "Select" }, class: "form-select" %>
    </div>
  </div>
  <div class="mt-3">
    <%= form.submit "Save", class: "btn btn-primary" %>
    <%= link_to "Cancel", admin_events_path, class: "btn btn-light" %>
  </div>
<% end %>
