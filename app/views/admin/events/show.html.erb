<% page_title "Event Details" %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="mb-1"><%= @event.title %></h2>
    <p class="text-muted mb-0">Event Details</p>
  </div>
  <div class="d-flex gap-2">
    <%= link_to edit_admin_event_path(@event), class: "btn btn-primary" do %>
      <i class="bi bi-pencil me-1"></i>Edit
    <% end %>
    <%= link_to admin_events_path, class: "btn btn-outline-secondary" do %>
      <i class="bi bi-arrow-left me-1"></i>Back
    <% end %>
  </div>
</div>

<div class="card border-0 shadow-sm">
  <div class="card-header bg-transparent border-0">
    <h5 class="mb-0">Details</h5>
  </div>
  <div class="card-body">
    <div class="row">
      <div class="col-md-6 mb-3"><div class="text-muted small">Title</div><div class="fw-medium"><%= display_attr(@event, :title) %></div></div>
      <div class="col-md-6 mb-3"><div class="text-muted small">Event Type</div><div class="fw-medium"><%= display_attr(@event, :event_type) %></div></div>
      <div class="col-md-6 mb-3"><div class="text-muted small">Start Date</div><div class="fw-medium"><%= display_attr(@event, :start_date) %></div></div>
      <div class="col-md-6 mb-3"><div class="text-muted small">End Date</div><div class="fw-medium"><%= display_attr(@event, :end_date) %></div></div>
      <div class="col-md-6 mb-3"><div class="text-muted small">Venue</div><div class="fw-medium"><%= display_attr(@event, :venue) %></div></div>
      <div class="col-md-6 mb-3"><div class="text-muted small">Description</div><div class="fw-medium"><%= display_attr(@event, :description) %></div></div>
      <div class="col-md-6 mb-3"><div class="text-muted small">Capacity</div><div class="fw-medium"><%= display_attr(@event, :capacity) %></div></div>
      <div class="col-md-6 mb-3"><div class="text-muted small">Registration Fee</div><div class="fw-medium"><%= display_attr(@event, :registration_fee) %></div></div>
      <div class="col-md-6 mb-3"><div class="text-muted small">Status</div><div class="fw-medium"><%= display_attr(@event, :status) %></div></div>
    </div>
  </div>
</div>
