<% page_title "Dashboard" %>
<div class="page-header">
  <h1><i class="bi bi-grid-3x3-gap-fill me-2"></i>Dashboard</h1>
  <span class="text-muted"><i class="bi bi-calendar3 me-1"></i><%= Date.current.strftime("%A, %d %B %Y") %></span>
</div>

<div class="row g-3 mb-4">
  <div class="col-md-4 col-xl-2">
    <div class="stat-card bg-gradient-blue">
      <i class="bi bi-people-fill stat-icon"></i>
      <div class="stat-value"><%= @total_members %></div>
      <div class="stat-label">Total Members</div>
    </div>
  </div>
  <div class="col-md-4 col-xl-2">
    <div class="stat-card bg-gradient-green">
      <i class="bi bi-person-check-fill stat-icon"></i>
      <div class="stat-value"><%= @active_members %></div>
      <div class="stat-label">Active Members</div>
    </div>
  </div>
  <div class="col-md-4 col-xl-2">
    <div class="stat-card bg-gradient-cyan">
      <i class="bi bi-person-plus-fill stat-icon"></i>
      <div class="stat-value"><%= @guests_this_month %></div>
      <div class="stat-label">Guests This Month</div>
    </div>
  </div>
  <div class="col-md-4 col-xl-2">
    <div class="stat-card bg-gradient-orange">
      <i class="bi bi-share-fill stat-icon"></i>
      <div class="stat-value"><%= @referrals_this_month %></div>
      <div class="stat-label">Referrals This Month</div>
    </div>
  </div>
  <div class="col-md-4 col-xl-2">
    <div class="stat-card bg-gradient-pink">
      <i class="bi bi-cash-coin stat-icon"></i>
      <div class="stat-value"><%= inr(@revenue_this_month) %></div>
      <div class="stat-label">Revenue This Month</div>
    </div>
  </div>
  <div class="col-md-4 col-xl-2">
    <div class="stat-card bg-gradient-amber">
      <i class="bi bi-arrow-repeat stat-icon"></i>
      <div class="stat-value"><%= @pending_renewals %></div>
      <div class="stat-label">Pending Renewals</div>
    </div>
  </div>
</div>

<div class="row g-3 mb-4">
  <div class="col-lg-6">
    <div class="card h-100"><div class="card-header">Member Growth</div>
      <div class="card-body"><%= line_chart @member_growth, colors: ["#667eea"], height: "260px" %></div>
    </div>
  </div>
  <div class="col-lg-6">
    <div class="card h-100"><div class="card-header">Attendance Breakdown</div>
      <div class="card-body"><%= column_chart @attendance_chart, colors: ["#11998e"], height: "260px" %></div>
    </div>
  </div>
</div>

<div class="row g-3 mb-4">
  <div class="col-lg-6">
    <div class="card h-100"><div class="card-header">Referral Trend</div>
      <div class="card-body"><%= line_chart @referral_trend, colors: ["#ff8a00"], height: "260px" %></div>
    </div>
  </div>
  <div class="col-lg-6">
    <div class="card h-100"><div class="card-header">Business Generated</div>
      <div class="card-body"><%= column_chart @business_generated, colors: ["#0072ff"], height: "260px" %></div>
    </div>
  </div>
</div>

<div class="row g-3">
  <div class="col-lg-5">
    <div class="card h-100"><div class="card-header">Recent Members</div>
      <div class="card-body p-0">
        <table class="table table-hover mb-0">
          <tbody>
          <% @recent_members.each do |m| %>
            <tr><td><%= link_to m.full_name, admin_member_path(m) %></td><td><%= m.company_name %></td><td class="text-end"><%= status_badge(m.membership_status) %></td></tr>
          <% end %>
          <% if @recent_members.empty? %><tr><td class="text-muted p-3">No members yet.</td></tr><% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
  <div class="col-lg-4">
    <div class="card h-100"><div class="card-header">Upcoming Meetings</div>
      <div class="card-body p-0">
        <table class="table mb-0">
          <tbody>
          <% @upcoming_meetings.each do |mtg| %>
            <tr><td><%= link_to (mtg.meeting_type.presence || "Meeting"), admin_weekly_meeting_path(mtg) %></td><td class="text-end text-muted"><%= mtg.meeting_date&.strftime("%d %b") %></td></tr>
          <% end %>
          <% if @upcoming_meetings.empty? %><tr><td class="text-muted p-3">No upcoming meetings.</td></tr><% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
  <div class="col-lg-3">
    <div class="card h-100 border-warning"><div class="card-header text-warning"><i class="bi bi-exclamation-triangle me-1"></i>Pending Renewals</div>
      <div class="card-body p-0">
        <table class="table mb-0">
          <tbody>
          <% @pending_renewal_members.each do |m| %>
            <tr><td><%= link_to m.full_name, admin_member_path(m) %></td></tr>
          <% end %>
          <% if @pending_renewal_members.empty? %><tr><td class="text-muted p-3">None.</td></tr><% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
